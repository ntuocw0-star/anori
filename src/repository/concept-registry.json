    {
      "id": "CON-000003",
      "tier": "tier_1",
      "canonical": "Community Participation",
      "zh": "社区参与",
      "en": "Community Participation",
      "aliases": [
        "社区参与",
        "连接",
        "Community Inclusion",
        "Civic Participation",
        "社会连接",
        "重新连接"
      ],
      "anori_definition": "不只是参加活动，而是感到自己仍然属于某个比家庭更大的世界。它可以是一位朋友、一个群组、一次散步，或者任何让人感到「外面还有我的位置」的事情。",
      "research_definition": "个体参与社区活动、社会角色和公共生活的程度。",
      "anori_reframe": "社区参与不需要恢复到以前的状态，而是在照顾之后，找到一个今天还能维持的连接。",
