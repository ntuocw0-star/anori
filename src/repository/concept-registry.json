    {
      "id": "CON-000008",
      "tier": "knowledge_operation",
      "canonical": "Reframe",
      "zh": "重新定义",
      "en": "Reframe",
      "aliases": [
        "重新定义",
        "重新理解",
        "Reframe",
        "重新框架"
      ],
      "anori_definition": "Anori 处理知识的核心操作。不是否定原有的理解，而是在保留原有感受的基础上，给它一个新的意义框架。每一页 Ending 都完成一次 Reframe。",
      "research_definition": "认知重评（Cognitive Reappraisal）：通过改变对情境的解释方式来调节情绪反应。",
      "anori_reframe": "（Reframe 本身就是操作，不需要被 Reframe。）",
      "operation_pattern": {
        "structure": "原有理解 → Anori Reframe → 新的意义",
        "examples": [
          {
            "original": "求助是承认失败",
            "reframe": "求助是让照顾不再只有你一个人承担"
          },
          {
            "original": "休息是奖励",
            "reframe": "休息是继续走下去的一部分"
          },
          {
            "original": "放弃一个选项是没有尽力",
            "reframe": "放弃是在保护整个家庭还能继续走下去"
          }
        ]
      },
