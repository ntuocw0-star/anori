  "concepts": [
    {
      "id": "CON-000001",
      "tier": "tier_1",
      "canonical": "Family Quality of Life",
      "zh": "家庭生活质量",
      "en": "Family Quality of Life",
      "aliases": [
        "家庭生活质量",
        "FQoL",
        "Family Well-being",
        "家庭整体状态"
      ],
      "anori_definition": "不是生活是否轻松，而是整个家庭是否还能维持自己认为重要的生活。它包括家庭关系的质量、照顾者的状态、孩子的发展，以及家庭还能不能做自己在乎的事情。",
      "research_definition": "家庭作为整体系统在多个生活领域的满意度与功能水平。",
      "anori_reframe": "家庭生活质量不是一个固定的标准，而是家庭在当前处境下还能维持的那个样子。",
