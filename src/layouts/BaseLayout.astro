---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
// CHANGE-008: Added DM Serif Display font (UI-001 Section 3)
// CHANGE-006: lang prop now dynamic for multilingual support (Master Spec Part 15.1)
export interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  lang?: string;
}
const {
  title = "Anori",
  description = "为有特殊需求孩子的家庭提供循证知识支持",
  keywords = [],
  lang = "zh-CN",
} = Astro.props;
const normalizedTitle = title.trim();
const alreadyBranded = normalizedTitle === 'Anori' || /(?:·|—|-|\|)\s*Anori$/.test(normalizedTitle);
const pageTitle = alreadyBranded ? normalizedTitle : `${normalizedTitle} — Anori`;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Noto+Sans+SC:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/png" href="/brand/logo.png" />
</head>
<body>
  <slot />
  <Analytics />
</body>
</html>
