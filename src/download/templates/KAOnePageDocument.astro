---
import type { KAOnePageBundle } from '../bundle-types';
interface Props { bundle: KAOnePageBundle; }
const { bundle } = Astro.props;
const s = bundle.sections;
---
<article class="onepage-doc" lang="zh-Hans">
  <div class="onepage-brand" aria-label="Anori">
    <img src="/brand/logo.png" alt="" width="28" height="28" />
    <span>Anori</span>
  </div>
  <header class="onepage-header">
    <p class="onepage-type">{s.type}</p>
    <h1>{bundle.title}</h1>
    {bundle.subtitle && <p class="onepage-subtitle">{bundle.subtitle}</p>}
    {bundle.summary && <p class="onepage-summary">{bundle.summary}</p>}
  </header>

  {bundle.keyPoints.length > 0 && <section><h2>{s.keyPoints}</h2><ol>{bundle.keyPoints.map(point => <li>{point}</li>)}</ol></section>}
  {bundle.whatYouCanDo.length > 0 && <section><h2>{s.whatYouCanDo}</h2><ul>{bundle.whatYouCanDo.map(item => <li>{item}</li>)}</ul></section>}
  {bundle.whatToAvoid.length > 0 && <section><h2>{s.whatToAvoid}</h2><ul>{bundle.whatToAvoid.map(item => <li>{item}</li>)}</ul></section>}
  {bundle.seekHelpIf.length > 0 && <section><h2>{s.seekHelpIf}</h2><ul class="seek-list">{bundle.seekHelpIf.map(item => <li>{item}</li>)}</ul></section>}

  <footer class="onepage-footer">
    <div>
      <p class="evidence-label">{s.evidence}</p>
      {bundle.evidence.level && <p><strong>证据等级：</strong>{bundle.evidence.level}</p>}
      {bundle.evidence.note && <p class="evidence-note">{bundle.evidence.note}</p>}
      {bundle.evidence.refs.length > 0 && <ul class="refs">{bundle.evidence.refs.map(ref => <li class:list={[ref.missing && 'missing']}><code>{ref.id}</code><span>{ref.title}</span></li>)}</ul>}
    </div>
    <div class="onepage-meta">
      <p>完整内容：<a href={bundle.source.canonicalUrl}>{bundle.source.canonicalUrl}</a></p>
      <p>知识库版本 {bundle.meta.repositoryVersion} · 摘要模板 {bundle.meta.schemaVersion}</p>
    </div>
  </footer>
</article>

<style>
.onepage-doc{max-width:720px;margin:0 auto;padding:var(--sp-10) var(--sp-8);font-size:var(--text-base);line-height:1.75;color:var(--ink)}
.onepage-brand{display:flex;align-items:center;gap:var(--sp-2);margin-bottom:var(--sp-5);font-size:var(--text-sm);font-weight:600;letter-spacing:-.01em;color:var(--ink)}
.onepage-brand img{display:block;width:28px;height:28px;object-fit:contain;flex-shrink:0}
.onepage-header{border-bottom:2px solid var(--ink);padding-bottom:var(--sp-6);margin-bottom:var(--sp-8)}
.onepage-type,.evidence-label{font-size:var(--text-xs);font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:var(--sp-2)}
.onepage-header h1{font-size:var(--text-3xl);line-height:1.3;margin:0 0 var(--sp-2)}
.onepage-subtitle{font-size:var(--text-lg);color:var(--muted);margin:0 0 var(--sp-4)}
.onepage-summary{color:var(--muted);border-left:3px solid var(--border);padding-left:var(--sp-4);margin:0}
.onepage-doc section{margin-bottom:var(--sp-8)}
.onepage-doc h2{font-size:var(--text-sm);text-transform:uppercase;letter-spacing:.07em;color:var(--muted);padding-bottom:var(--sp-2);border-bottom:1px solid var(--border);margin-bottom:var(--sp-4)}
.onepage-doc ol,.onepage-doc ul{padding-left:1.25rem}.onepage-doc li+li{margin-top:var(--sp-2)}.seek-list{color:var(--muted)}
.onepage-footer{border-top:1px solid var(--border);padding-top:var(--sp-6);display:flex;flex-direction:column;gap:var(--sp-5)}
.evidence-note,.onepage-meta{font-size:var(--text-sm);color:var(--muted)}.refs{list-style:none;padding:0}.refs li{display:flex;gap:var(--sp-3);align-items:baseline}.refs code{font-family:var(--mono);font-size:.72rem;background:var(--paper-warm);padding:.1rem .35rem;border-radius:3px}.refs .missing{opacity:.55}.onepage-meta p{margin:.2rem 0}.onepage-meta a{color:var(--brand)}
@media(max-width:560px){.onepage-doc{padding:var(--sp-6) var(--sp-4)}.onepage-header h1{font-size:var(--text-2xl)}}
@media print{.onepage-doc{max-width:none;padding:0;font-size:9.6pt}.onepage-brand{margin-bottom:10pt}.onepage-brand img{width:22px;height:22px}.onepage-header h1{font-size:16pt}.onepage-doc section{break-inside:avoid}.onepage-footer{break-inside:avoid}.onepage-meta a{color:inherit;text-decoration:none}}
</style>
