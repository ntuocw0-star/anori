---
import Breadcrumb from '../Breadcrumb.astro';
import seriesData from '../../repository/library/series.json';
import topicsData from '../../repository/library/topics.json';
import { TERMS } from '../../i18n/terminology';

export interface ContentMeta {
  id: string;
  type: 'EA' | 'ET' | 'KA';
  title: string;
  summary?: string;
  updatedAt?: string;
  status?: 'draft' | 'reviewed' | 'published';
  seriesIds: string[];
}

export interface NavItem {
  id: string;
  title: string;
  href: string;
}

export interface SeriesNav {
  seriesId: string;
  seriesLabel: string;
  seriesHref: string;
  prev: NavItem | null;
  next: NavItem | null;
}

interface Props {
  meta: ContentMeta;
  seriesNavList: SeriesNav[];
}

const { meta, seriesNavList } = Astro.props;
const allSeries = (seriesData as any).series as any[];
const allTopics = (topicsData as any).topics as any[];
const resolvedSeries = meta.seriesIds.map(id => allSeries.find(s => s.id === id)).filter(Boolean);
const resolvedTopics = resolvedSeries
  .map(s => allTopics.find(t => t.id === s.topic))
  .filter((topic, index, arr) => topic && arr.findIndex(item => item?.id === topic.id) === index);
const primarySeries = resolvedSeries[0];
const primaryTopic = resolvedTopics[0];
const bridgeQuery = primaryTopic?.label ?? meta.title;
const breadcrumbItems = [
  { label: '首页', href: '/' },
  { label: TERMS.library.label, href: '/library' },
  ...(primaryTopic ? [{ label: primaryTopic.label, href: `/library/${primaryTopic.slug}` }] : []),
  ...(primarySeries ? [{ label: primarySeries.label, href: primarySeries.canonical }] : []),
  { label: meta.title },
];
---
<div class="content-page">
  <Breadcrumb items={breadcrumbItems} />

  <header class="content-hero">
    <span class:list={['content-type-badge', `content-type-badge--${meta.type.toLowerCase()}`]}>
      {meta.type === 'EA' ? TERMS.ea.label : meta.type === 'ET' ? TERMS.et.label : TERMS.ka.label}
    </span>
    <h1>{meta.title}</h1>
    <dl class="content-meta-list">
      <div><dt>ID</dt><dd><code>{meta.id}</code></dd></div>
      {resolvedTopics.length > 0 && <div><dt>{TERMS.topic.label}</dt><dd>{resolvedTopics.map((t, i) => <>{i > 0 && '、'}<a href={`/library/${t.slug}`}>{t.label}</a></>)}</dd></div>}
      {resolvedSeries.length > 0 && <div><dt>{TERMS.series.label}</dt><dd>{resolvedSeries.map((s, i) => <>{i > 0 && '、'}<a href={s.canonical}>{s.label}</a></>)}</dd></div>}
      {meta.updatedAt && <div><dt>更新时间</dt><dd><time datetime={meta.updatedAt}>{meta.updatedAt}</time></dd></div>}
    </dl>
    {meta.summary && <p class="content-summary">{meta.summary}</p>}
  </header>

  <main class="content-body"><slot name="body" /></main>

  {(Astro.slots.has('related-series') || Astro.slots.has('related-topic')) && (
    <aside class="content-related">
      <h2>相关内容</h2>
      <slot name="related-series" />
      <slot name="related-topic" />
    </aside>
  )}

  {Astro.slots.has('download') && <section class="content-download"><slot name="download" /></section>}

  {seriesNavList.length > 0 && (
    <nav class="series-nav-list" aria-label={`${TERMS.series.label}导航`}>
      {seriesNavList.map(nav => (
        <div class="series-nav-block">
          <a href={nav.seriesHref} class="series-return">↑ 返回「{nav.seriesLabel}」</a>
          <div class="series-prev-next">
            <div>{nav.prev ? <a class="series-nav-link" href={nav.prev.href}><span>← 上一篇</span><strong>{nav.prev.title}</strong></a> : <span class="series-empty">已是第一篇</span>}</div>
            <div>{nav.next ? <a class="series-nav-link series-nav-link--next" href={nav.next.href}><span>下一篇 →</span><strong>{nav.next.title}</strong></a> : <span class="series-empty">已是最后一篇</span>}</div>
          </div>
        </div>
      ))}
    </nav>
  )}

  <section class="search-bridge">
    <p>还想继续查找相关内容？</p>
    <a href={`/search?q=${encodeURIComponent(bridgeQuery)}`}>在{TERMS.search.label}中继续探索 →</a>
  </section>
</div>

<style>
.content-page{max-width:720px;margin:0 auto;padding:var(--sp-6)}
.content-hero{padding:var(--sp-10) 0 var(--sp-8);border-bottom:1px solid var(--border);margin-bottom:var(--sp-8)}
.content-hero h1{font-size:var(--text-3xl);line-height:1.3;margin:var(--sp-3) 0 var(--sp-4)}
.content-type-badge{display:inline-block;padding:.2rem .55rem;border-radius:var(--radius-sm);font-size:var(--text-xs);font-weight:700;letter-spacing:.08em;background:var(--surface-card)}
.content-type-badge--ea{color:#1d4ed8;background:#eff6ff}.content-type-badge--et{color:#15803d;background:#f0fdf4}.content-type-badge--ka{color:#7e22ce;background:#fdf4ff}
.content-meta-list{display:flex;flex-wrap:wrap;gap:var(--sp-2) var(--sp-8);font-size:var(--text-sm);margin-bottom:var(--sp-4)}
.content-meta-list div{display:flex;gap:var(--sp-2)}.content-meta-list dt{color:var(--muted)}.content-meta-list dd{margin:0}.content-meta-list a{color:var(--brand)}
.content-meta-list code{font-family:var(--mono);font-size:.78rem;background:var(--paper-warm);padding:.1rem .35rem;border-radius:3px}
.content-summary{color:var(--muted);border-left:3px solid var(--border);padding-left:var(--sp-4);line-height:1.75}
.content-body{margin-bottom:var(--sp-10)}
.content-related,.content-download,.series-nav-list,.search-bridge{border-top:1px solid var(--border);padding-top:var(--sp-6);margin-bottom:var(--sp-8)}
.content-related>h2{font-size:var(--text-sm);text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:var(--sp-4)}
.series-nav-list{display:flex;flex-direction:column;gap:var(--sp-6)}.series-nav-block{display:flex;flex-direction:column;gap:var(--sp-3)}
.series-return{font-size:var(--text-sm);color:var(--muted)}.series-prev-next{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-3)}
.series-nav-link{display:flex;flex-direction:column;padding:var(--sp-4);border:1px solid var(--border);border-radius:var(--radius);background:var(--surface);font-size:var(--text-sm)}
.series-nav-link span{color:var(--muted);font-size:var(--text-xs)}.series-nav-link--next{text-align:right}.series-empty{display:block;padding:var(--sp-4);font-size:var(--text-sm);color:var(--muted-lt)}
.search-bridge p{font-size:var(--text-sm);color:var(--muted)}.search-bridge a{color:var(--brand);font-size:var(--text-sm)}
@media(max-width:560px){.content-page{padding:var(--sp-4)}.content-hero h1{font-size:var(--text-2xl)}.series-prev-next{grid-template-columns:1fr}.series-nav-link--next{text-align:left}}
</style>
