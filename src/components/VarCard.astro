---
// C-004 VarCard — reads Var object
import { varTypeColor } from "../lib/repository";
export interface Props {
  id: string;
  canonical_name: string;
  chinese_name: string;
  variable_type: string;
  definition: string;
  aliases?: string[];
}
const { id, canonical_name, chinese_name, variable_type, definition, aliases = [] } = Astro.props;
const bg = varTypeColor[variable_type] ?? "#EDECE8";
---

<div class="var-card">
  <div class="var-header">
    <span class="var-type" style={`background:${bg}`}>{variable_type}</span>
  </div>
  <h3 class="var-name">{chinese_name}</h3>
  <p class="var-name-en">{canonical_name}</p>
  {definition && <p class="var-def">{definition}</p>}
  {aliases.length > 0 && <p class="var-aliases">又称：{aliases.join("、")}</p>}
</div>

<style>
.var-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); padding: var(--sp-5) var(--sp-6); transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  display: flex; flex-direction: column; gap: var(--sp-2);
}
.var-card:hover {
  border-color: var(--muted-lt);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.var-header { display: flex; }
.var-type {
  font-size: var(--text-xs); font-weight: 600;
  padding: 2px 8px; border-radius: var(--radius-pill); color: var(--ink);
}
.var-name { font-size: var(--text-lg); font-weight: 600; line-height: 1.3; }
.var-name-en { font-size: var(--text-xs); color: var(--muted-lt); font-style: italic; }
.var-def { font-size: var(--text-sm); color: var(--ink); line-height: 1.8; }
.var-aliases { font-size: var(--text-xs); color: var(--muted); }
</style>

