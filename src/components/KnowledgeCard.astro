---
// C-006 KnowledgeCard — updated Sprint 1
// CHANGE-002: Added Confidence Line (signature element, CARD-001 Section 3, Master Spec Part 14.3)
// CHANGE-003: Added ConfidenceBadge (ECS-001 Section 3)
import ConfidenceBadge from "./ConfidenceBadge.astro";

export interface Props {
  topic: string;
  title: string;
  relation_label: string;
  body: string;
  observations: [string, string, string];
  source_summary: string;
  href?: string;
  evidence_grade?: string; // NEW: from REL evidence_grade
}
const { topic, title, relation_label, body, observations, source_summary, href, evidence_grade = "" } = Astro.props;

// Confidence Line color mapping (Master Spec Part 14.3)
const lineColor: Record<string, string> = {
  High:      "var(--confidence-high)",
  Low:       "var(--confidence-medium)",
  "Very Low": "var(--confidence-low)",
};
const borderColor = lineColor[evidence_grade] ?? "#DDD9D0";
---

<div class="kc" style={`border-left: 3px solid ${borderColor};`}>
  <div class="kc-header">
    <p class="kc-topic">{topic}</p>
    <h3 class="kc-title">{title}</h3>
    <div class="kc-meta">
      <span class="kc-label">{relation_label}</span>
      {evidence_grade && <ConfidenceBadge grade={evidence_grade} />}
    </div>
  </div>

  <div class="kc-body">
    <p set:html={body} />
  </div>

  <div class="kc-observe">
    <p class="kc-obs-label">👀 可以观察</p>
    <ul class="kc-obs-list">
      {observations.map(obs => (
        <li class="kc-obs-item">
          <span class="kc-check" role="checkbox" aria-checked="false" tabindex="0"
            onclick="this.setAttribute('aria-checked', this.getAttribute('aria-checked')==='true'?'false':'true')"
            onkeydown="if(event.key===' '||event.key==='Enter'){this.click();event.preventDefault()}"
          ></span>
          <span>{obs}</span>
        </li>
      ))}
    </ul>
  </div>

  <details class="kc-ref">
    <summary>研究来源</summary>
    <div class="detail-body">
      <p>{source_summary}</p>
    </div>
  </details>

  <div class="kc-actions">
    <button class="pill-btn" id="fav-btn"
      onclick="this.textContent=this.textContent.includes('已')? '❤️ 收藏':'❤️ 已收藏'">
      ❤️ 收藏
    </button>
    <button class="pill-btn"
      onclick="this.textContent='谢谢你的反馈';this.disabled=true">
      🌿 对你有帮助吗？
    </button>
    {href && (
      <a href={href} class="kc-more">了解更多 →</a>
    )}
  </div>
</div>

<style>
.kc {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: var(--radius); overflow: hidden;
  /* border-left is set inline from evidence_grade */
}
.kc-header {
  padding: var(--sp-6); border-bottom: 1px solid var(--border);
  display: flex; flex-direction: column; gap: var(--sp-2);
}
.kc-topic {
  font-size: var(--text-xs); font-weight: 600;
  letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--muted);
}
.kc-title {
  font-size: var(--text-xl); font-weight: 600;
  letter-spacing: -0.01em; line-height: 1.4;
}
.kc-meta {
  display: flex; align-items: center; gap: var(--sp-3); flex-wrap: wrap;
}
.kc-label {
  font-size: var(--text-xs); background: var(--paper-warm);
  padding: 3px 8px; border-radius: var(--radius-sm);
  color: var(--muted); display: inline-block;
}
.kc-body {
  padding: var(--sp-6); font-size: var(--text-sm);
  line-height: 1.9; color: var(--ink);
}
.kc-observe {
  padding: var(--sp-5) var(--sp-6);
  background: var(--paper-warm); border-top: 1px solid var(--border);
}
.kc-obs-label {
  font-size: var(--text-xs); font-weight: 600;
  letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--muted); margin-bottom: var(--sp-4);
}
.kc-obs-list { list-style: none; display: flex; flex-direction: column; gap: var(--sp-3); }
.kc-obs-item {
  display: flex; align-items: flex-start; gap: var(--sp-3);
  font-size: var(--text-sm); color: var(--ink); line-height: 1.7;
}
.kc-check {
  width: 16px; height: 16px; border: 1.5px solid var(--border);
  border-radius: var(--radius-sm); flex-shrink: 0; margin-top: 3px;
  background: var(--surface); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.kc-check[aria-checked="true"] {
  background: var(--ink); border-color: var(--ink);
}
.kc-check[aria-checked="true"]::after { content: '✓'; color: white; font-size: 10px; }

.kc-ref {
  border-top: 1px solid var(--border); border-radius: 0;
}
.kc-ref summary {
  padding: var(--sp-3) var(--sp-6);
  font-size: var(--text-xs); color: var(--muted-lt); font-weight: 400;
}
.kc-ref .detail-body {
  padding: var(--sp-3) var(--sp-6) var(--sp-4); border: none;
}
.kc-ref .detail-body p { font-size: var(--text-xs); color: var(--muted-lt); }

.kc-actions {
  padding: var(--sp-4) var(--sp-6); border-top: 1px solid var(--border);
  display: flex; gap: var(--sp-3); align-items: center; flex-wrap: wrap;
}
.kc-more {
  margin-left: auto; font-size: var(--text-xs);
  color: var(--ink); border-bottom: 1px solid var(--border);
}
.kc-more:hover { border-color: var(--ink); }
</style>

