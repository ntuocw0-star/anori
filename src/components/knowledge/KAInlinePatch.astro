---
import KAConceptCard from "./KAConceptCard.astro";

interface RelatedKA {
  id?: string;
  title?: string;
  href?: string;
  [key: string]: unknown;
}

export interface Props {
  relatedKAs?: RelatedKA[];
}

const { relatedKAs = [] } = Astro.props;
---

{relatedKAs.length > 0 && (
  <section class="ka-inline">
    <div class="ka-inline-head">
      <p class="ka-inline-label">相关知识概念</p>
      <h2>理解这个问题时，可以一起看的几个概念</h2>
    </div>

    <div class="ka-inline-list">
      {relatedKAs.map((ka: RelatedKA) => (
        <KAConceptCard prod={ka} />
      ))}
    </div>
  </section>
)}

<style>
  .ka-inline {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 0.5px solid var(--border);
  }

  .ka-inline-head {
    margin-bottom: var(--sp-4);
  }

  .ka-inline-label {
    margin: 0 0 0.25rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .ka-inline h2 {
    margin: 0;
    font-size: 1.05rem;
    color: var(--text-primary);
  }

  .ka-inline-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }
</style>