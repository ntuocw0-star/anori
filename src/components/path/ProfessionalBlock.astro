---
export interface Props {
  if_have?: string;
  if_not?: string;
}
const { if_have, if_not } = Astro.props;
---
<section class="up-section">
  <div class="up-professional">
    {if_have && (
      <div class="up-professional-row">
        <span class="up-professional-icon">👩‍⚕️</span>
        <div>
          <p class="up-professional-label">如果你目前有专业人员</p>
          <p class="up-professional-text">{if_have}</p>
        </div>
      </div>
    )}
    {if_not && (
      <div class="up-professional-row">
        <span class="up-professional-icon">✓</span>
        <div>
          <p class="up-professional-label">暂时没有也不用担心</p>
          <p class="up-professional-text">{if_not}</p>
        </div>
      </div>
    )}
  </div>
</section>
