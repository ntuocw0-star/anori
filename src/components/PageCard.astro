---
// C-001 PageCard
export interface Props {
  id: string;
  slug: string;
  title: string;
  trigger: string;   // 家长语言，trigger_statements[0]
  label: string;     // 主题标签（原 subtitle）
}
const { slug, title, trigger, label } = Astro.props;
---

<a href={`/${slug}`} class="page-card">
  <p class="card-label">{title}</p>
  <p class="card-trigger">{trigger}</p>
  <div class="card-footer">了解这个主题 →</div>
</a>

<style>
.page-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: var(--sp-4) var(--sp-5);
  display: flex; flex-direction: column; gap: var(--sp-2);
  transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  color: inherit; min-height: 96px;
}
.page-card:hover {
  border-color: var(--muted-lt);
  box-shadow: var(--shadow-sm);
}
.card-label {
  font-size: var(--text-xs); font-weight: 600;
  letter-spacing: 0.06em; text-transform: uppercase;
  color: var(--muted);
}
.card-trigger {
  font-size: var(--text-sm); color: var(--ink);
  line-height: 1.55; flex: 1;
}
.card-footer {
  font-size: var(--text-xs); color: var(--muted-lt);
  padding-top: var(--sp-2);
  border-top: 1px solid var(--border);
  margin-top: auto;
}
</style>

