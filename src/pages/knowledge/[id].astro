---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import knowledgeData from "../../repository/knowledge.json";

export async function getStaticPaths() {
  return (knowledgeData as any).articles.map((ka: any) => ({
    params: { id: ka.id.toLowerCase() },
    props: { article: ka },
  }));
}

const { article: ka } = Astro.props as any;

const pageTitle = `${ka.title} — Anori 知识`;
const pageDesc = ka.subtitle ?? ka.one_sentence ?? "";

const relatedPaths: Record<string, { label: string; href: string }> = {
  p001: { label: "孩子不会说话", href: "/paths/p001/journey" },
  p002: { label: "孩子不会表达情绪", href: "/paths/p002/journey" },
  p003: { label: "孩子行为问题", href: "/paths/p003/journey" },
  p004: { label: "孩子学校适应", href: "/paths/p004/journey" },
  p005: { label: "孩子社交参与", href: "/paths/p005/journey" },
  p006: { label: "我已经很累了", href: "/paths/p006/journey" },
};
---

<BaseLayout title={pageTitle} description={pageDesc}>
<SiteNav />

<div class="ka-top">
  <div class="wrap">
    <Breadcrumb items={[
      { label: "首页", href: "/" },
      { label: "知识", href: "/search" },
      { label: ka.title },
    ]} />
    <p class="ka-eyebrow">知识文章</p>
    <h1 class="ka-title">{ka.title}</h1>
    {ka.subtitle && <p class="ka-subtitle">{ka.subtitle}</p>}
    {ka.evidence_level && (
      <div class="ka-badge-row">
        <span class="ka-badge ka-badge--evidence">证据等级：{ka.evidence_level}</span>
        {ka.topic && <span class="ka-badge">{ka.topic}</span>}
      </div>
    )}
  </div>
</div>

<div class="wrap ka-layout">
  <main class="ka-main">

    {/* 核心结论 */}
    {ka.one_sentence && (
      <div class="ka-lead">
        <p class="ka-lead-text">{ka.one_sentence}</p>
      </div>
    )}

    {/* 正文 */}
    {ka.body && (
      <section class="ka-section">
        <p class="ka-body">{ka.body}</p>
      </section>
    )}

    {/* 研究发现 */}
    {ka.key_findings?.length > 0 && (
      <section class="ka-section">
        <p class="ka-section-label">研究告诉我们什么</p>
        <ul class="ka-findings">
          {(ka.key_findings as string[]).map((f: string) => (
            <li class="ka-finding-item">{f}</li>
          ))}
        </ul>
      </section>
    )}

    {/* 今天可以做什么 */}
    {ka.what_you_can_do?.length > 0 && (
      <section class="ka-section">
        <p class="ka-section-label">今天可以做什么</p>
        <ol class="ka-actions">
          {(ka.what_you_can_do as string[]).map((a: string) => (
            <li class="ka-action-item">{a}</li>
          ))}
        </ol>
      </section>
    )}

    {/* 今天不要做什么 */}
    {ka.what_to_avoid?.length > 0 && (
      <section class="ka-section">
        <p class="ka-section-label">今天不要做什么</p>
        <ul class="ka-avoid">
          {(ka.what_to_avoid as string[]).map((a: string) => (
            <li class="ka-avoid-item">{a}</li>
          ))}
        </ul>
      </section>
    )}

    {/* 何时寻求帮助 */}
    {ka.seek_help_if?.length > 0 && (
      <section class="ka-section">
        <p class="ka-section-label">什么时候需要专业帮助</p>
        <ul class="ka-seek-help">
          {(ka.seek_help_if as string[]).map((s: string) => (
            <li class="ka-seek-help-item">{s}</li>
          ))}
        </ul>
      </section>
    )}

    {/* 相关路径 */}
    {ka.related_path?.length > 0 && (
      <section class="ka-section">
        <p class="ka-section-label">相关路径</p>
        <div class="ka-paths">
          {(ka.related_path as string[]).map((pid: string) => {
            const p = relatedPaths[pid];
            return p ? (
              <a href={p.href} class="ka-path-card">
                <span class="ka-path-title">{p.label}</span>
                <span class="ka-path-arrow">→</span>
              </a>
            ) : null;
          })}
        </div>
      </section>
    )}

    {/* 证据来源 */}
    {ka.related_ea?.length > 0 && (
      <section class="ka-section">
        <p class="ka-section-label">证据来源</p>
        <div class="ka-evidence-list">
          {(ka.related_ea as string[]).map((eaId: string) => (
            <div class="ka-evidence-item">
              <span class="ka-evidence-id">{eaId}</span>
              {ka.evidence_note && (
                <span class="ka-evidence-note">{ka.evidence_note}</span>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    {/* 系列导航 */}
    {ka.series && (ka.series.previous || ka.series.next) && (
      <section class="ka-section">
        <p class="ka-section-label">系列文章 · {ka.series.name}</p>
        <div class="ka-series-nav">
          {ka.series.previous && (
            <a href={`/knowledge/${ka.series.previous.toLowerCase()}`} class="ka-series-link ka-series-link--prev">
              <span class="ka-series-dir">← 上一篇</span>
              <span class="ka-series-label">返回系列</span>
            </a>
          )}
          {ka.series.next && (
            <a href={`/knowledge/${ka.series.next.toLowerCase()}`} class="ka-series-link ka-series-link--next">
              <span class="ka-series-dir">下一篇 →</span>
              <span class="ka-series-label">继续阅读</span>
            </a>
          )}
        </div>
      </section>
    )}

  </main>

  <aside class="ka-aside">
    {ka.series && (
      <div class="ka-aside-card">
        <p class="ka-aside-label">所属系列</p>
        <p class="ka-aside-value">{ka.series.name}</p>
        <p class="ka-aside-note">第 {ka.series.order} 篇</p>
      </div>
    )}
    <div class="ka-aside-card">
      <p class="ka-aside-label">这篇文章基于</p>
      <p class="ka-aside-value">真实研究综述</p>
      {ka.evidence_note && (
        <p class="ka-aside-note">{ka.evidence_note}</p>
      )}
    </div>
    {ka.tags?.length > 0 && (
      <div class="ka-aside-card">
        <p class="ka-aside-label">相关主题</p>
        <div class="ka-tags">
          {(ka.tags as string[]).map((tag: string) => (
            <a href={`/search?q=${encodeURIComponent(tag)}`} class="ka-tag">{tag}</a>
          ))}
        </div>
      </div>
    )}
    <div class="ka-aside-card">
      <p class="ka-aside-label">还在找什么？</p>
      <a href="/search" class="ka-aside-link">搜索其他情况 →</a>
      <a href="/" class="ka-aside-link">回到首页</a>
    </div>
  </aside>
</div>

<SiteFooter />
</BaseLayout>

<style>
.ka-top {
  background: #FDFCF9;
  border-bottom: 1px solid var(--border);
  padding: var(--sp-12) 0 var(--sp-10);
}
.ka-eyebrow {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--muted); margin-bottom: var(--sp-3);
}
.ka-title {
  font-size: var(--text-3xl); font-weight: 600;
  letter-spacing: -0.02em; line-height: 1.25;
  margin-bottom: var(--sp-3); color: var(--ink);
}
.ka-subtitle {
  font-size: var(--text-lg); color: var(--muted);
  line-height: 1.7; max-width: 560px; margin-bottom: var(--sp-4);
}
.ka-badge-row { display: flex; gap: var(--sp-2); flex-wrap: wrap; }
.ka-badge {
  font-size: var(--text-xs); color: var(--muted);
  background: rgba(148,136,120,0.08); border: 1px solid var(--border);
  border-radius: var(--radius-pill); padding: var(--sp-1) var(--sp-3);
}
.ka-badge--evidence { color: #5B9E7A; border-color: rgba(91,158,122,0.3); background: rgba(91,158,122,0.06); }

.ka-layout {
  display: grid; grid-template-columns: 1fr 220px;
  gap: var(--sp-16); align-items: start;
  padding-top: var(--sp-12); padding-bottom: var(--sp-24);
}
.ka-main { display: flex; flex-direction: column; gap: var(--sp-10); }

.ka-lead {
  padding: var(--sp-5) var(--sp-6);
  background: #EEF4FB; border-left: 3px solid #2D6A8F;
  border-radius: 0 8px 8px 0;
}
.ka-lead-text { font-size: var(--text-base); font-weight: 600; color: #1E4A6A; line-height: 1.6; }

.ka-section { display: flex; flex-direction: column; gap: var(--sp-4); }
.ka-section-label {
  font-size: 10px; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--muted-lt);
  padding-bottom: var(--sp-3); border-bottom: 1px solid var(--border);
}
.ka-body {
  font-size: var(--text-base); color: var(--ink);
  line-height: 1.85; max-width: var(--max-prose);
}

.ka-findings { display: flex; flex-direction: column; gap: var(--sp-3); list-style: none; padding: 0; }
.ka-finding-item {
  padding: var(--sp-3) var(--sp-4) var(--sp-3) var(--sp-8);
  background: #FDFCF8; border: 1px solid rgba(160,148,132,0.14);
  border-radius: var(--radius-md); font-size: var(--text-sm); color: var(--ink);
  line-height: 1.7; position: relative;
}
.ka-finding-item::before {
  content: "✓"; position: absolute; left: var(--sp-3);
  color: #5B9E7A; font-weight: 800; font-size: var(--text-xs); top: var(--sp-3);
}

.ka-actions { display: flex; flex-direction: column; gap: var(--sp-3); padding-left: 0; list-style: none; counter-reset: action; }
.ka-action-item {
  counter-increment: action;
  padding: var(--sp-4) var(--sp-5) var(--sp-4) calc(var(--sp-5) + 2rem);
  background: #F3F7FB; border-radius: var(--radius-md);
  font-size: var(--text-sm); color: var(--ink); line-height: 1.7;
  position: relative;
}
.ka-action-item::before {
  content: counter(action); position: absolute;
  left: var(--sp-4); top: 50%; transform: translateY(-50%);
  width: 1.5rem; height: 1.5rem; border-radius: 50%;
  background: #2D6A8F; color: white;
  font-size: var(--text-xs); font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}

.ka-seek-help { display: flex; flex-direction: column; gap: var(--sp-2); list-style: none; padding: 0; }
.ka-seek-help-item {
  padding: var(--sp-3) var(--sp-4);
  background: rgba(148,136,120,0.05);
  border-radius: var(--radius); font-size: var(--text-sm);
  color: var(--muted); line-height: 1.65;
}

.ka-paths { display: flex; flex-direction: column; gap: var(--sp-2); }
.ka-path-card {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--sp-4) var(--sp-5);
  background: #F3F7FB; border-left: 3px solid #2D6A8F;
  border-radius: 0 8px 8px 0; text-decoration: none;
  transition: background 0.15s;
}
.ka-path-card:hover { background: #E8EFF7; }
.ka-path-title { font-size: var(--text-sm); font-weight: 600; color: var(--ink); }
.ka-path-arrow { font-size: var(--text-sm); color: #2D6A8F; }

.ka-evidence-list { display: flex; flex-direction: column; gap: var(--sp-3); }
.ka-evidence-item {
  display: flex; flex-direction: column; gap: var(--sp-1);
  padding: var(--sp-4) var(--sp-5);
  background: #FDFCF8; border: 1px solid rgba(160,148,132,0.14);
  border-radius: var(--radius-md);
}
.ka-evidence-id { font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.06em; color: var(--muted); }
.ka-evidence-note { font-size: var(--text-sm); color: var(--ink); line-height: 1.6; }

.ka-aside { position: sticky; top: 80px; display: flex; flex-direction: column; gap: var(--sp-3); }
.ka-aside-card {
  background: #FDFCF8; border: 1px solid rgba(160,148,132,0.14);
  border-radius: var(--radius-lg); padding: var(--sp-4) var(--sp-5);
  display: flex; flex-direction: column; gap: var(--sp-2);
}
.ka-aside-label { font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted-lt); }
.ka-aside-value { font-size: var(--text-sm); font-weight: 600; color: var(--ink); }
.ka-aside-note { font-size: var(--text-xs); color: var(--muted); line-height: 1.6; }
.ka-aside-link { font-size: var(--text-sm); color: var(--muted); text-decoration: none; border-bottom: 1px solid var(--border); padding-bottom: var(--sp-1); transition: color 0.15s; }
.ka-aside-link:hover { color: var(--ink); }
.ka-tags { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
.ka-tag { font-size: var(--text-xs); color: var(--muted); background: rgba(148,136,120,0.07); border: 1px solid var(--border); border-radius: var(--radius-pill); padding: 2px var(--sp-3); text-decoration: none; transition: background 0.15s; }
.ka-tag:hover { background: rgba(148,136,120,0.14); color: var(--ink); }

.ka-avoid { display: flex; flex-direction: column; gap: var(--sp-2); list-style: none; padding: 0; }
.ka-avoid-item {
  padding: var(--sp-3) var(--sp-4) var(--sp-3) var(--sp-8);
  background: rgba(186,117,23,0.05);
  border-left: 2px solid rgba(186,117,23,0.3);
  border-radius: 0 6px 6px 0;
  font-size: var(--text-sm); color: var(--ink); line-height: 1.7;
  position: relative;
}
.ka-avoid-item::before {
  content: "○"; position: absolute; left: var(--sp-3);
  color: #BA7517; font-size: var(--text-xs); top: var(--sp-3);
}

.ka-series-nav {
  display: flex; gap: var(--sp-3); flex-wrap: wrap;
}
.ka-series-link {
  display: flex; flex-direction: column; gap: 2px;
  padding: var(--sp-3) var(--sp-4);
  background: #F3F7FB; border-radius: var(--radius-md);
  text-decoration: none; flex: 1; min-width: 120px;
  transition: background 0.15s; border: 1px solid var(--border);
}
.ka-series-link:hover { background: #E8EFF7; }
.ka-series-link--prev { border-left: 3px solid var(--muted-lt); }
.ka-series-link--next { border-left: 3px solid #2D6A8F; }
.ka-series-dir { font-size: var(--text-xs); color: #2D6A8F; font-weight: 600; }
.ka-series-label { font-size: var(--text-xs); color: var(--muted); }

.up-evidence-ka { margin-top: var(--sp-4); padding-top: var(--sp-4); border-top: 1px solid rgba(255,255,255,0.15); }
.up-evidence-ka-link { display: flex; align-items: center; gap: var(--sp-2); text-decoration: none; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: var(--radius); padding: var(--sp-2) var(--sp-4); transition: background 0.15s; }
.up-evidence-ka-link:hover { background: rgba(255,255,255,0.14); }
.up-evidence-ka-label { font-size: 9px; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; color: #B8C8F0; flex-shrink: 0; }
.up-evidence-ka-title { font-size: var(--text-xs); color: white; flex: 1; line-height: 1.4; }
.up-evidence-ka-arrow { font-size: var(--text-xs); color: #B8C8F0; flex-shrink: 0; }

@media (max-width: 860px) {
  .ka-layout { grid-template-columns: 1fr; }
  .ka-aside { position: static; flex-direction: row; flex-wrap: wrap; }
  .ka-aside-card { flex: 1; min-width: 140px; }
}
@media (max-width: 480px) { .ka-title { font-size: var(--text-2xl); } }
</style>
