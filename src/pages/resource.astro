---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import ResourceCard from "../components/ResourceCard.astro";
import resourcesData from "../repository/resources.json";
import pagesData from "../repository/pages.json";

const allResources = (resourcesData as any).resources ?? [];

// URL 参数过滤（topic）
const topicParam = Astro.url.searchParams.get("topic") ?? "";
const resources = topicParam
  ? allResources.filter((r: any) =>
      Array.isArray(r.related_pages) && r.related_pages.includes(topicParam)
    )
  : allResources;

const allPages = (pagesData as any).pages ?? [];
const topicPage = topicParam ? allPages.find((p: any) => p.slug === topicParam) : null;
const topicLabel = topicPage?.title ?? topicParam;

const isEmpty = resources.length === 0 && !topicParam;

const originalResources = [
  {
    id: "RI-ANORI-0001",
    title: "First–Then 视觉支持卡",
    title_en: "First–Then Visual Support Card",
    description: '帮助家庭用清晰的“先做—然后”结构呈现活动顺序。提供预填版与空白版，可打印或在手机上使用。',
    status: "ready",
    version: "1.0.0",
    preview: "/downloads/resources/RI-ANORI-0001/first-then-card-prefilled-mobile.png",
    downloads: [
      {
        label: "下载预填版 PDF",
        href: "/downloads/resources/RI-ANORI-0001/first-then-card-prefilled.pdf",
      },
      {
        label: "下载空白版 PDF",
        href: "/downloads/resources/RI-ANORI-0001/first-then-card-blank.pdf",
      },
    ],
  },
];

// resource_type → sidebar slug 映射
// International Organization 单独保留，不并入 ngo
const TYPE_TO_SLUG: Record<string, string> = {
  "Government Agency":         "government",
  "Guideline Organization":    "guidelines",
  "Professional Organization": "professional",
  "Non-profit Organization":   "ngo",
  "NGO Resource":              "ngo",
  "Research Website":          "research",
  "Assessment / Screening":    "assessment",
  "International Organization":"international",
};

// 统计每个 slug 的资源数量
const countBySlug: Record<string, number> = { all: resources.length };
for (const r of resources) {
  const slug = TYPE_TO_SLUG[r.resource_type] ?? "other";
  countBySlug[slug] = (countBySlug[slug] ?? 0) + 1;
}

// 侧边栏分类列表
const sidebarCats = [
  { slug: "international", label: "国际组织",   count: countBySlug["international"] ?? 0 },
  { slug: "government",    label: "政府资源",   count: countBySlug["government"]    ?? 0 },
  { slug: "ngo",           label: "非营利组织",  count: countBySlug["ngo"]           ?? 0 },
  { slug: "professional",  label: "专业组织",   count: countBySlug["professional"]  ?? 0 },
  { slug: "guidelines",    label: "指南与标准",  count: countBySlug["guidelines"]    ?? 0 },
  { slug: "assessment",    label: "评估与筛查",  count: countBySlug["assessment"]    ?? 0 },
  { slug: "research",      label: "研究与循证",  count: countBySlug["research"]      ?? 0 },
  { slug: "family",        label: "家庭支持",   count: 0,  disabled: true },
];
---

<BaseLayout title="资源" description="国际循证资源库 — 政府指南、NGO 支持、专业工具">
<SiteNav active="resource" />

<div class="res-page">
  <div class="wrap">

    <!-- 顶部 -->
    <div class="res-hero">
      <Breadcrumb items={[
        { label: "首页", href: "/" },
        { label: "资源", href: "/resource" },
        ...(topicParam ? [{ label: topicLabel }] : []),
      ]} />
      <h1 class="res-title">{topicParam ? `${topicLabel} · 相关资源` : "资源库"}</h1>
      <p class="res-desc">
        {topicParam
          ? `共 ${resources.length} 份与「${topicLabel}」相关的资源。`
          : <>来自国际组织、政府机构和专业协会的可信资源。<br/>每一条都经过筛选，适合家长和照顾者直接使用。</>
        }
      </p>
      {topicParam && (
        <a href="/resource" class="res-clear-filter">查看全部资源 →</a>
      )}
    </div>

    {originalResources.length > 0 && (
      <section class="original-resources">
        <div class="original-header">
          <p class="original-eyebrow">ANORI ORIGINALS</p>
          <h2>Anori 原创资源</h2>
          <p>打开即可理解，拿来即可使用，设计有据可依。</p>
        </div>

        <div class="original-grid">
          {originalResources.map((resource) => (
            <article class="original-card">
              <img
                src={resource.preview}
                alt={`${resource.title}预览`}
                class="original-preview"
              />

              <div class="original-content">
                <div class="original-meta">
                  <span class="original-status">可使用</span>
                  <span>v{resource.version}</span>
                </div>

                <h3>{resource.title}</h3>
                <p class="original-title-en">{resource.title_en}</p>
                <p class="original-description">{resource.description}</p>

                <div class="original-actions">
                  {resource.downloads.map((download) => (
                    <a href={download.href} download>
                      {download.label}
                    </a>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {isEmpty ? (
      <div class="res-empty">
        <div class="res-empty-inner">
          <p class="res-empty-label">资源整理中</p>
          <h2 class="res-empty-title">第一批资源正在整理。</h2>
          <p class="res-empty-body">
            我们会陆续收录来自国际组织、政府机构和专业协会的可信资源，
            按照与 Repository 同等的质量标准逐条审核后导入。
          </p>
          <p class="res-empty-note">
            如果你知道某个优质资源还没有收录，欢迎告诉我们。
          </p>
        </div>
      </div>
    ) : (
      <div class="res-layout">

        <!-- 分类侧边 -->
        <aside class="res-sidebar">
          <p class="res-sidebar-label">资源分类</p>
          <nav class="res-nav" id="res-filter-nav">
            <button class="res-nav-item active" data-filter="all">
              全部资源
              <span class="res-nav-count">{resources.length}</span>
            </button>
            {sidebarCats.map((cat: any) => (
              cat.disabled ? (
                <span class="res-nav-item res-nav-item--disabled" aria-disabled="true">
                  {cat.label}
                  <span class="res-nav-badge">建设中</span>
                </span>
              ) : (
                <button class="res-nav-item" data-filter={cat.slug}>
                  {cat.label}
                  <span class="res-nav-count">{cat.count}</span>
                </button>
              )
            ))}
          </nav>
        </aside>

        <!-- 资源网格 -->
        <div>
          <p class="res-filter-label" id="res-filter-label" aria-live="polite"></p>
          <div class="res-filter-empty" id="res-filter-empty" hidden>
            <p>该分类暂无资源。</p>
          </div>
          <main class="res-grid" id="res-grid">
            {resources.map((r: any) => {
              const enriched = r.id === 'RES-000001' || r.id === 'RES-000016' || r.id === 'RES-000004';
              return (
                <div class="res-card-wrap" data-type={TYPE_TO_SLUG[r.resource_type] ?? "other"}>
                  <ResourceCard
                    id={r.id}
                    title={r.title}
                    title_zh={r.title_zh}
                    organization={r.organization}
                    organization_short={r.organization_short}
                    countries={r.countries}
                    resource_type={r.resource_type}
                    audience={r.audience}
                    topic_tags={r.topic_tags}
                    language={r.language}
                    access={r.access}
                    description={r.description}
                    description_zh={r.description_zh}
                    url={r.url}
                    related_pages={r.related_pages}
                    enriched={enriched}
                    entry_question={r.entry_question}
                    recommendation_reason={r.recommendation_reason}
                    key_points={r.key_points}
                  />
                </div>
              );
            })}
          </main>
        </div>

      </div>
    )}

  </div>
</div>

<SiteFooter />
</BaseLayout>

<script>
(function () {
  const nav   = document.getElementById('res-filter-nav');
  const grid  = document.getElementById('res-grid');
  const label = document.getElementById('res-filter-label');
  const empty = document.getElementById('res-filter-empty');
  if (!nav || !grid) return;

  const cards = Array.from(grid.querySelectorAll('.res-card-wrap'));
  const btns  = Array.from(nav.querySelectorAll('button[data-filter]'));

  function applyFilter(slug) {
    let shown = 0;
    for (const card of cards) {
      const match = slug === 'all' || card.dataset.type === slug;
      card.hidden = !match;
      if (match) shown++;
    }
    if (empty)  empty.hidden  = shown > 0;
    if (label)  label.textContent = slug === 'all' ? '' : `已筛选：${shown} 个资源`;
    for (const btn of btns) {
      btn.classList.toggle('active', btn.dataset.filter === slug);
    }
  }

  for (const btn of btns) {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter || 'all'));
  }
})();
</script>

<style>
.res-page {
  min-height: 80vh;
  background: #F8F6F1;
  padding: var(--sp-20) 0 var(--sp-24);
}
.res-hero { margin-bottom: var(--sp-12); }
.res-title {
  font-size: var(--text-3xl); font-weight: 600;
  letter-spacing: -0.03em; margin-bottom: var(--sp-3);
}
.res-desc { font-size: var(--text-base); color: var(--muted); line-height: 1.8; }
.res-clear-filter {
  display: inline-block; margin-top: var(--sp-3);
  font-size: var(--text-sm); color: var(--brand); font-weight: 500;
}
.res-empty { max-width: 680px; }
.res-empty-inner {
  background: #FDFCF8;
  border: 1px solid rgba(160,148,132,0.14);
  border-radius: var(--radius-lg); padding: var(--sp-10);
  box-shadow: var(--shadow-sm);
}
.res-empty-label {
  font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted-lt); margin-bottom: var(--sp-3);
}
.res-empty-title {
  font-size: var(--text-3xl); font-weight: 600;
  letter-spacing: -0.03em; line-height: 1.2; margin-bottom: var(--sp-4);
}
.res-empty-body {
  font-size: var(--text-base); color: var(--muted);
  line-height: 1.85; margin-bottom: var(--sp-8);
}
.res-empty-note { font-size: var(--text-xs); color: var(--muted-lt); font-style: italic; }
.res-layout { display: grid; grid-template-columns: 200px 1fr; gap: var(--sp-12); }
.res-sidebar { display: flex; flex-direction: column; gap: var(--sp-2); }
.res-sidebar-label {
  font-size: 10px; font-weight: 500; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--muted-lt);
  margin-bottom: var(--sp-3); margin-top: var(--sp-2);
}
.res-sidebar-label:first-child { margin-top: 0; }
.res-nav { display: flex; flex-direction: column; gap: 2px; }
.res-nav-item {
  all: unset; box-sizing: border-box;
  display: flex; align-items: center; justify-content: space-between;
  font-size: var(--text-sm); color: var(--muted);
  padding: var(--sp-2) var(--sp-3); border-radius: var(--radius);
  transition: background 0.15s, color 0.15s;
  cursor: pointer; width: 100%; line-height: 1.5;
}
.res-nav-item:hover { background: rgba(148,136,120,0.08); color: var(--ink); }
.res-nav-item.active { background: rgba(148,136,120,0.12); color: var(--ink); font-weight: 500; }
.res-nav-item--disabled { opacity: 0.45; cursor: not-allowed; pointer-events: none; }
.res-nav-count {
  font-size: 10px; color: var(--muted-lt);
  background: rgba(148,136,120,0.08);
  padding: 1px 6px; border-radius: 99px; flex-shrink: 0;
}
.res-nav-badge {
  font-size: 10px; color: var(--muted-lt);
  border: 1px solid var(--border);
  padding: 1px 6px; border-radius: 99px; flex-shrink: 0;
}
.res-filter-label {
  font-size: var(--text-xs); color: var(--muted);
  margin-bottom: var(--sp-4); min-height: 1.5em;
}
.res-filter-empty {
  padding: var(--sp-10); text-align: center;
  color: var(--muted); font-size: var(--text-sm);
}
.res-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--sp-5); }
@media (max-width: 900px) {
  .res-layout { grid-template-columns: 1fr; }
  .res-sidebar { flex-direction: row; flex-wrap: wrap; gap: var(--sp-2); }
  .res-nav { flex-direction: row; flex-wrap: wrap; }
  .res-nav-item { width: auto; font-size: var(--text-xs); padding: var(--sp-2) var(--sp-3); }
  .res-grid { grid-template-columns: 1fr; }
}

.original-resources {
  margin-bottom: var(--sp-16);
}

.original-header {
  margin-bottom: var(--sp-6);
}

.original-eyebrow {
  margin-bottom: var(--sp-2);
  color: var(--brand);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
}

.original-header h2 {
  margin-bottom: var(--sp-2);
  font-size: var(--text-2xl);
}

.original-header > p:last-child {
  color: var(--muted);
  line-height: 1.7;
}

.original-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--sp-5);
}

.original-card {
  overflow: hidden;
  background: #fdfcf8;
  border: 1px solid rgba(160, 148, 132, 0.18);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.original-preview {
  display: block;
  width: 100%;
  height: 280px;
  object-fit: contain;
  background: #f4f1eb;
}

.original-content {
  padding: var(--sp-6);
}

.original-meta {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-bottom: var(--sp-3);
  color: var(--muted-lt);
  font-size: var(--text-xs);
}

.original-status {
  padding: 2px 8px;
  color: var(--brand);
  background: rgba(37, 99, 235, 0.08);
  border-radius: 99px;
  font-weight: 600;
}

.original-card h3 {
  margin-bottom: 2px;
  font-size: var(--text-xl);
}

.original-title-en {
  margin-bottom: var(--sp-4);
  color: var(--muted-lt);
  font-size: var(--text-sm);
}

.original-description {
  color: var(--muted);
  line-height: 1.75;
}

.original-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-3);
  margin-top: var(--sp-5);
}

.original-actions a {
  padding: var(--sp-2) var(--sp-4);
  color: white;
  background: var(--brand);
  border-radius: var(--radius);
  font-size: var(--text-sm);
  font-weight: 500;
}

@media (max-width: 900px) {
  .original-grid {
    grid-template-columns: 1fr;
  }

  .original-preview {
    height: 240px;
  }
}
</style>
