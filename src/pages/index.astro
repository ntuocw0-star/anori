---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
import PageCard from "../components/PageCard.astro";
import { pages, vars, rels } from "../lib/repository";
import problemsData from "../repository/problems.json";

const CATEGORY_ORDER = ["emotion", "communication", "sleep", "school", "caregiver"] as const;
type CategoryKey = typeof CATEGORY_ORDER[number];

const CATEGORY_LABEL: Record<CategoryKey, string> = {
  emotion:       "情绪",
  communication: "沟通",
  sleep:         "睡眠",
  school:        "学校",
  caregiver:     "照顾者",
};

const problemsByCategory = CATEGORY_ORDER.map((cat: CategoryKey) => ({
  cat,
  label: CATEGORY_LABEL[cat],
  items: problemsData.problems.filter(p => p.category === cat).slice(0, 2),
}));

// 辅助选择入口 — 全部指向对应 Journey，不使用子页面路由
const assistEntries = [
  {
    cat: "孩子说话与沟通",
    items: [
      { title: "孩子不开口，或者越来越少说话", href: "/problems/prb-0006" },
      { title: "不知道孩子想表达什么", href: "/problems/prb-0010" },
    ],
  },
  {
    cat: "孩子情绪与崩溃",
    items: [
      { title: "孩子一点小事就崩溃，我不知道怎么帮", href: "/problems/prb-0001" },
      { title: "孩子很难平静，情绪持续很久", href: "/problems/prb-0002" },
    ],
  },
  {
    cat: "孩子行为",
    items: [
      { title: "孩子打人、咬人，或者伤害自己", href: "/paths/p003/journey" },
      { title: "孩子有重复行为，不知道背后是什么原因", href: "/paths/p003/u001" },
    ],
  },
  {
    cat: "学校与适应",
    items: [
      { title: "孩子不愿意去学校，或者放学就崩溃", href: "/problems/prb-0016" },
      { title: "老师反映有问题，不知道怎么和学校配合", href: "/problems/prb-0017" },
    ],
  },
  {
    cat: "社交与连结",
    items: [
      { title: "孩子在人群里很难加入，一个人站着", href: "/problems/prb-0019" },
      { title: "孩子和同学关系越来越差，或者总被排斥", href: "/problems/prb-0020" },
    ],
  },
  {
    cat: "家长自己",
    items: [
      { title: "我已经很累了，不知道还能撑多久", href: "/paths/p006/journey" },
      { title: "我担心自己做得不够好，总是自责", href: "/paths/p006/s001" },
    ],
  },
];
---

<BaseLayout title="Anori" description="为有特殊需求孩子的家庭提供循证知识支持">
<SiteNav active="home" />

<!-- ① Hero -->
<section class="hero">
  <div class="hero-bg">
    <img
      src="/images/hero-illustration.jpg"
      alt="一位家长和孩子坐在草地上，平静地望向远方"
      class="hero-img"
      loading="eager"
    />
  </div>
  <div class="wrap hero-inner">
    <div class="hero-text">
      <p class="eyebrow">循证家庭支持</p>
      <h1 class="hero-title">
        每个孩子都值得被理解，<br>
        <em>而不是只被一个标签定义。</em>
      </h1>
      <p class="hero-body">
        照顾一个有特殊需求的孩子，最难的不是找到答案，<br>
        而是弄清楚究竟在面对什么。
      </p>
      <p class="hero-body-2">
        Anori 整理来自国际研究的家庭支持知识，
        帮助你看见正在发生的事——而不是替你下结论。
      </p>
      <div class="hero-search">
        <a href="/search" class="search-prompt">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="6.5" cy="6.5" r="4.5" stroke="#7A7570" stroke-width="1.5"/>
            <path d="M10 10 L14 14" stroke="#7A7570" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span class="search-placeholder">试试搜索：压力、休息、争吵、服务…</span>
          <span class="search-enter">搜索</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ② P001–P005 行动路径（主入口） -->
<section class="paths-section">
  <div class="wrap">
    <div class="paths-header">
      <p class="paths-eyebrow">行动路径</p>
      <h2 class="paths-title">从孩子的情况开始</h2>
      <p class="paths-sub">每条路径对应一个真实的家长处境，一步一步带你走到今天可以做的事。</p>
    </div>
    <p class="paths-guide">不知道从哪里开始也没关系，选择一个最接近你今天情况的入口。</p>
    <div class="paths-grid">
      <a href="/paths/p001/journey" class="path-card">
        <p class="path-card-sentence">不会说话不等于不会沟通。今天可以从一张图片开始。</p>
        <p class="path-card-title">孩子不会说话</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
      <a href="/paths/p002/journey" class="path-card">
        <p class="path-card-sentence">崩溃不是脾气问题。先读懂来源，再决定支持方式。</p>
        <p class="path-card-title">孩子不会表达情绪</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
      <a href="/paths/p003/journey" class="path-card">
        <p class="path-card-sentence">行为是信息，不是问题。找到来源，才能真正帮到孩子。</p>
        <p class="path-card-title">孩子行为问题</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
      <a href="/paths/p004/journey" class="path-card">
        <p class="path-card-sentence">学校不是另一个战场，而是支持系统的一部分。</p>
        <p class="path-card-title">孩子学校适应</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
      <a href="/paths/p005/journey" class="path-card">
        <p class="path-card-sentence">社交不是让孩子变成别的样子，而是帮他找到属于他的方式。</p>
        <p class="path-card-title">孩子社交参与</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
      <a href="/paths/p006/journey" class="path-card path-card--caregiver">
        <p class="path-card-sentence">你一直在支撑孩子，却很少有人问过：你还撑得住吗？</p>
        <p class="path-card-title">我已经很累了，该怎么办？</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
      <a href="/paths/p007/journey" class="path-card">
        <p class="path-card-sentence">剪头发崩溃、怕吸尘器、一直转圈——这些可能来自同一个原因。</p>
        <p class="path-card-title">感觉处理</p>
        <span class="path-card-cta">进入路径 →</span>
      </a>
    </div>
  </div>
</section>

<!-- ③ 辅助选择入口 -->
<section class="assist-section">
  <div class="wrap">
    <div class="assist-header">
      <h2 class="assist-title">不确定从哪条路径开始？</h2>
      <p class="assist-sub">找一个最接近你现在情况的描述，进入对应的路径。</p>
    </div>
    <div class="assist-grid">
      {assistEntries.map(({ cat, items }) => (
        <div class="assist-group">
          <p class="assist-group-label">{cat}</p>
          <ul class="assist-list">
            {items.map(item => (
              <li>
                <a href={item.href} class="assist-link">
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <p class="assist-more">
      还没找到？
      <a href="/search" class="assist-more-link">去搜索里说一句你的情况 →</a>
    </p>
  </div>
</section>

<!-- ④ 知识探索（九大主题） -->
<section class="cards-section">
  <div class="wrap">
    <div class="cards-header">
      <p class="cards-eyebrow">知识探索</p>
      <h2 class="cards-title">探索更多家庭主题</h2>
      <p class="cards-sub">来自国际研究的家庭支持知识，帮助你看见正在发生的事。</p>
    </div>
    <div class="grid-3">
      {pages.map(p => (
        <PageCard
          id={p.id}
          slug={p.slug}
          title={p.title}
          trigger={p.trigger_statements[0] ?? ""}
          label={p.subtitle}
        />
      ))}
    </div>
  </div>
</section>

<!-- ⑤ 深入阅读研究 -->
<section class="library-section">
  <div class="wrap">
    <div class="library-header">
      <p class="library-eyebrow">深入阅读</p>
      <h2 class="library-title">深入阅读研究</h2>
      <p class="library-sub">Anori 整理的国际研究证据与知识摘要，供希望进一步了解证据来源的家长与专业读者查阅。</p>
    </div>
    <div class="library-grid">
      <a href="/library" class="library-card">
        <p class="library-card-label">文献库</p>
        <p class="library-card-desc">浏览研究证据、知识摘要与专题。</p>
        <span class="library-card-cta">进入文献库 →</span>
      </a>
      <a href="/library" class="library-card">
        <p class="library-card-label">研究证据（EA）</p>
        <p class="library-card-desc">浏览国际研究。</p>
        <span class="library-card-cta">浏览研究 →</span>
      </a>
      <a href="/library" class="library-card">
        <p class="library-card-label">知识摘要（KA）</p>
        <p class="library-card-desc">用简明结构理解一个主题的核心知识。</p>
        <span class="library-card-cta">阅读摘要 →</span>
      </a>
    </div>
  </div>
</section>

<!-- ⑥ 原则区 -->
<section class="principle-section">
  <div class="wrap">
    <p class="principle-text">
      不把孩子当病人。不随便定义孩子。<br>
      帮助观察，而不是帮助判断。
    </p>
    <a href="/about" class="principle-link">了解 Anori 的立场 →</a>
  </div>
</section>

<SiteFooter />
</BaseLayout>

<style>
/* ── Hero ─────────────────────────────────────────────────── */
.hero {
  position: relative;
  background: #F7F5F0;
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  left: 10%; right: -5%; top: -4%; bottom: -4%;
  pointer-events: none;
  -webkit-mask-image: linear-gradient(
    to right,
    transparent 0%, rgba(0,0,0,0.05) 8%, rgba(0,0,0,0.35) 20%,
    rgba(0,0,0,0.80) 32%, black 42%, black 100%
  );
  mask-image: linear-gradient(
    to right,
    transparent 0%, rgba(0,0,0,0.05) 8%, rgba(0,0,0,0.35) 20%,
    rgba(0,0,0,0.80) 32%, black 42%, black 100%
  );
}
.hero-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: 35% center; display: block;
}
.hero-inner {
  position: relative; z-index: 2;
  min-height: 580px; display: flex; align-items: center;
}
.hero-text { max-width: 460px; padding: var(--sp-16) 0; }
.eyebrow {
  font-size: var(--text-xs); font-weight: 600;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--brand); margin-bottom: var(--sp-5);
}
.hero-title {
  font-size: var(--text-4xl); font-weight: 400;
  font-family: var(--font-display);
  letter-spacing: -0.02em; line-height: 1.2;
  margin-bottom: var(--sp-6); color: var(--ink);
}
.hero-title em { font-style: normal; color: var(--muted); font-weight: 400; }
.hero-body {
  font-size: var(--text-lg); color: var(--ink);
  line-height: 1.75; max-width: 520px; margin-bottom: var(--sp-3);
}
.hero-body-2 {
  font-size: var(--text-base); color: var(--muted);
  line-height: 1.8; max-width: 480px; margin-bottom: var(--sp-8);
}
.hero-search { max-width: 440px; }
.search-prompt {
  display: flex; align-items: center; gap: var(--sp-3);
  background: var(--paper); border: 1.5px solid var(--border);
  border-radius: var(--radius-pill); padding: var(--sp-3) var(--sp-4) var(--sp-3) var(--sp-5);
  transition: border-color 0.15s, box-shadow 0.15s; color: inherit;
}
.search-prompt:hover {
  border-color: var(--ink); box-shadow: var(--shadow-sm);
}
.search-placeholder { flex: 1; font-size: var(--text-sm); color: var(--muted-lt); }
.search-enter {
  font-size: var(--text-xs); font-weight: 600;
  background: var(--ink); color: white;
  padding: var(--sp-2) var(--sp-4); border-radius: var(--radius-pill); white-space: nowrap;
}

/* ── ② P001–P005 行动路径（主入口） ─────────────────────── */
.paths-section {
  padding: var(--sp-16) 0;
  background: #EEF4FB;
  border-top: 1px solid #C8D8EC;
  border-bottom: 1px solid #C8D8EC;
}
.paths-eyebrow {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: #2D6A8F; margin-bottom: var(--sp-2);
}
.paths-header { margin-bottom: var(--sp-8); }
.paths-title {
  font-size: var(--text-3xl); font-weight: 600;
  letter-spacing: -0.02em; color: var(--ink); margin-bottom: var(--sp-2);
}
.paths-sub { font-size: var(--text-sm); color: var(--muted); line-height: 1.7; }
.paths-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-4);
}
@media (max-width: 860px) { .paths-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 540px) { .paths-grid { grid-template-columns: 1fr; } }
.path-card {
  display: flex; flex-direction: column; gap: var(--sp-3);
  padding: var(--sp-6) var(--sp-5);
  background: white;
  border: 1.5px solid #B8CCE0;
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
}
.path-card:hover {
  border-color: #2D6A8F;
  background: #F5F9FD;
  box-shadow: 0 4px 16px rgba(45,106,143,0.12);
}
.path-card-sentence {
  font-size: var(--text-sm); color: var(--muted); line-height: 1.75; flex: 1;
}
.path-card-title {
  font-size: var(--text-lg); font-weight: 700; color: var(--ink);
}
.path-card-cta {
  font-size: var(--text-xs); font-weight: 600;
  color: #2D6A8F;
  padding-top: var(--sp-3);
  border-top: 1px solid #C8D8EC;
  margin-top: var(--sp-1);
}
/* P006 家长路径：暖黄色区分，视觉上与孩子路径有别 */
.path-card--caregiver {
  border-color: #D4A820;
  background: #FFFBF0;
}
.path-card--caregiver:hover {
  border-color: #B8870A;
  background: #FFF8E6;
  box-shadow: 0 4px 16px rgba(180,130,0,0.12);
}
.path-card--caregiver .path-card-cta {
  color: #8A6000;
  border-top-color: #E8D48A;
}

/* ── ③ 辅助选择入口 ──────────────────────────────────────── */
.assist-section {
  padding: var(--sp-14) 0 var(--sp-16);
  background: #FDFCF9;
  border-bottom: none;
}
.assist-header { margin-bottom: var(--sp-8); }
.assist-title {
  font-size: var(--text-xl); font-weight: 600;
  letter-spacing: -0.01em; color: var(--ink); margin-bottom: var(--sp-2);
}
.assist-sub { font-size: var(--text-sm); color: var(--muted); line-height: 1.7; }

/* 3列布局，每个分组是独立卡片 */
.assist-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 24px 28px;
  margin-bottom: var(--sp-8);
}
@media (max-width: 860px) { .assist-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 20px; } }
@media (max-width: 540px) { .assist-grid { grid-template-columns: 1fr; gap: 16px; } }

/* 每个分组作为轻量卡片 */
.assist-group {
  padding: 20px 22px;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  background: rgba(255,255,255,0.7);
}
.assist-group-label {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--muted);
  margin-bottom: var(--sp-3);
  padding-bottom: var(--sp-2);
  border-bottom: 1px solid var(--border);
}
.assist-list {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: var(--sp-2);
}
.assist-link {
  display: block; font-size: var(--text-sm); color: var(--ink);
  line-height: 1.7; padding: var(--sp-2) 0;
  border-bottom: 1px solid transparent;
  transition: color 0.15s, border-color 0.15s;
}
.assist-link::before { content: "○  "; color: var(--muted-lt); font-size: 0.75em; }
.assist-link:hover { color: var(--brand); border-color: var(--border); }
.assist-more { font-size: var(--text-sm); color: var(--muted); margin-top: var(--sp-2); }
.assist-more-link {
  color: var(--ink); border-bottom: 1px solid var(--border);
}
.assist-more-link:hover { border-color: var(--ink); }

/* ── ④ 知识探索（九大主题，轻量目录入口） ────────────────── */
.cards-section {
  padding: var(--sp-12) 0 var(--sp-14);
  background: var(--paper-warm);
  border-top: 2px solid var(--border);
  margin-top: var(--sp-16);   /* 与上方区块的明显留白 */
}
.cards-eyebrow {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--muted-lt); margin-bottom: var(--sp-1);
}
.cards-header { margin-bottom: var(--sp-5); }
.cards-title {
  font-size: var(--text-xl); font-weight: 500;
  letter-spacing: -0.01em; margin-bottom: var(--sp-1); color: var(--muted);
}
.cards-sub { font-size: var(--text-xs); color: var(--muted-lt); line-height: 1.6; }

/* ── 引导文案 ─────────────────────────────────────────────── */
.paths-guide {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.75;
  margin-bottom: var(--sp-6);
  padding: var(--sp-4) var(--sp-5);
  background: rgba(255,255,255,0.6);
  border-left: 3px solid #B8CCE0;
  border-radius: 0 var(--radius) var(--radius) 0;
}

/* ── ⑤ 深入阅读研究 ──────────────────────────────────────── */
.library-section {
  padding: var(--sp-12) 0 var(--sp-14);
  background: var(--surface);
  border-top: 1px solid var(--border);
}
.library-header { margin-bottom: var(--sp-6); }
.library-eyebrow {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--muted-lt); margin-bottom: var(--sp-1);
}
.library-title {
  font-size: var(--text-xl); font-weight: 500;
  letter-spacing: -0.01em; color: var(--muted);
  margin-bottom: var(--sp-1);
}
.library-sub {
  font-size: var(--text-xs); color: var(--muted-lt); line-height: 1.6;
}
.library-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-4);
}
@media (max-width: 860px) { .library-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 540px) { .library-grid { grid-template-columns: 1fr; } }

.library-card {
  display: flex; flex-direction: column; gap: var(--sp-2);
  padding: var(--sp-5) var(--sp-5);
  background: var(--paper);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.library-card:hover {
  border-color: var(--muted-lt);
  box-shadow: var(--shadow-sm);
}
.library-card-label {
  font-size: var(--text-sm); font-weight: 600;
  color: var(--ink);
}
.library-card-desc {
  font-size: var(--text-xs); color: var(--muted);
  line-height: 1.6; flex: 1;
}
.library-card-cta {
  font-size: var(--text-xs); font-weight: 600;
  color: var(--brand);
  margin-top: var(--sp-2);
  padding-top: var(--sp-2);
  border-top: 1px solid var(--border);
}

/* ── ⑥ 原则区 ────────────────────────────────────────────── */
.principle-section {
  padding: var(--sp-16) 0 var(--sp-24);
  border-top: 1px solid var(--border);
}
.principle-text {
  font-size: var(--text-xl); color: var(--muted);
