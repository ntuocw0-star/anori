---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteNav from "../../components/SiteNav.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { pages, resources } from "../../lib/repository";
import problemsData from "../../repository/problems.json";
import methodsData from "../../repository/methods.json";
import KAInlinePatch from "../../components/knowledge/KAInlinePatch.astro";
export async function getStaticPaths() {
  return problemsData.problems.map(p => ({
    params: { id: p.id.toLowerCase() },
    props: { problem: p },
  }));
}

const { problem: p } = Astro.props as any;
// 读取所有 PROD JSON
const prodFiles = import.meta.glob("../../../knowledge/production/*.json", {
  eager: true,
});

// 根据 related_kas 找对应的 PROD
const relatedKAs = (p.related_kas ?? [])
  .map((slug: string) => {
    const key = Object.keys(prodFiles).find((k) => k.includes(slug));
    return key ? (prodFiles as any)[key]: null;
  })
  .filter(Boolean);
const CATEGORY_LABEL: Record<string, string> = {
  emotion:       "情绪",
  communication: "沟通",
  sleep:         "睡眠",
  school:        "学校",
  caregiver:     "照顾者",
};

const relatedMethods = (p.related_methods ?? [])
  .map((id: string) => methodsData.methods.find(m => m.id === id))
  .filter(Boolean);

const relatedPages = (p.related_pages ?? [])
  .map((entry: any) => {
    const slug = typeof entry === "string" ? entry : entry.slug;
    const why = typeof entry === "string" ? null : (entry.why_worth_reading ?? null);
    const pg = pages.find((p: any) => p.slug === slug);
    return pg ? { ...pg, why_worth_reading: why } : null;
  })
  .filter(Boolean);

const relatedResources = (p.related_resources ?? [])
  .map((entry: any) => {
    const rid = typeof entry === "string" ? entry : entry.id;
    const why = typeof entry === "string" ? null : (entry.why_recommended ?? null);
    const res = resources.find((r: any) => r.id === rid);
    return res ? { ...res, why_recommended: why } : null;
  })
  .filter(Boolean);
---

<BaseLayout
  title={`${p.title} — Anori`}
  description={`关于「${p.title}」的方法、知识和资源整理。`}
>
<SiteNav />

<!-- 顶部 -->
<div class="pb-top">
  <div class="wrap">
    <Breadcrumb items={[
      { label: "首页", href: "/" },
      { label: CATEGORY_LABEL[p.category] ?? "问题", href: "/" },
      { label: p.title },
    ]} />
    <p class="pb-eyebrow">{CATEGORY_LABEL[p.category] ?? "家长问题"}</p>
    <h1 class="pb-title">{p.title}</h1>
    <p class="pb-intro">
      {p.intro ?? "很多家长都会先注意到这样的变化。下面整理了一些可能对你有帮助的方向。"}
    </p>
    {p.aliases?.length > 0 && (
      <div class="pb-aliases">
        {p.aliases.map((a: string) => (
          <span class="pb-alias">{a}</span>
        ))}
      </div>
    )}
  </div>
</div>

<!-- 行动入口 -->
<div class="pb-anchor-wrap">
  <div class="wrap">
    <p class="pb-anchor-lead">面对这个问题，你可以选择：</p>
    <div class="pb-anchor-grid">
      <a href="#methods" class="pb-anchor-card pb-anchor-card--method">
        <p class="pb-anchor-title">🧭 我想知道现在可以做什么</p>
        <p class="pb-anchor-desc">看看可以尝试的思路</p>
        <span class="pb-anchor-cta">开始 →</span>
      </a>
      <a href="#pages" class="pb-anchor-card pb-anchor-card--page">
        <p class="pb-anchor-title">📘 我想先了解为什么会这样</p>
        <p class="pb-anchor-desc">阅读相关知识</p>
        <span class="pb-anchor-cta">开始 →</span>
      </a>
      <a href="#resources" class="pb-anchor-card pb-anchor-card--resource">
        <p class="pb-anchor-title">📚 我想看看国际资源怎么说</p>
        <p class="pb-anchor-desc">查看整理好的资源</p>
        <span class="pb-anchor-cta">开始 →</span>
      </a>
    </div>
  </div>
</div>

<!-- 主体 -->
<div class="wrap pb-layout">
  <main class="pb-main">

    <!-- 相关知识概念 -->
    {relatedKAs.length > 0 && (
      <KAInlinePatch relatedKAs={relatedKAs} />
    )}

    <!-- 方法层 -->
    {relatedMethods.length > 0 && (
      <section class="pb-section" id="methods">
        <p class="pb-section-label">可以先参考的方法</p>
        <div class="pb-methods">
          {relatedMethods.map((m: any) => (
            <div class="pb-method-card">
              <h3 class="pb-method-name">{m.name}</h3>
              <p class="pb-method-core">{m.core_message}</p>
              {m.when_to_use && (
                <p class="pb-method-when">{m.when_to_use}</p>
              )}
              {m.first_step && (
                <p class="pb-method-first-step">
                  <span class="pb-method-first-step-label">可以试试：</span>{m.first_step}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- 知识页层 -->
    {relatedPages.length > 0 && (
      <section class="pb-section" id="pages">
        <p class="pb-section-label">推荐阅读</p>
        <div class="pb-pages">
          {relatedPages.map((pg: any) => (
            <a href={`/${pg.slug}`} class="pb-page-card">
              <h3 class="pb-page-title">{pg.title}</h3>
              <p class="pb-page-trigger">{pg.trigger_statements?.[0] ?? pg.subtitle ?? ""}</p>
              {pg.why_worth_reading && (
                <p class="pb-page-why">
                  <span class="pb-page-why-label">为什么值得读：</span>{pg.why_worth_reading}
                </p>
              )}
              <span class="pb-page-cta">阅读完整主题 →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 资源层 -->
    {relatedResources.length > 0 && (
      <section class="pb-section" id="resources">
        <p class="pb-section-label">推荐资源</p>
        <div class="pb-resources">
          {relatedResources.map((r: any) => (
            <a href={`/resource/${r.id}`} class="pb-resource-card">
              <p class="pb-resource-org">{r.organization_short ?? r.organization}</p>
              <h3 class="pb-resource-title">{r.title_zh ?? r.title}</h3>
              {r.entry_question && (
                <p class="pb-resource-entry">{r.entry_question}</p>
              )}
              {r.why_recommended && (
                <p class="pb-resource-why">
                  <span class="pb-resource-why-label">为什么推荐：</span>{r.why_recommended}
                </p>
              )}
              <span class="pb-resource-cta">查看资源 →</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 底部引导 -->
    <div class="pb-footer">
      <p class="pb-footer-text">这些内容不完全符合你的情况？也没关系，每个孩子都不同。</p>
      <div class="pb-footer-links">
        <a href="/search" class="pb-footer-search">换一种说法搜索 →</a>
        <a href="/" class="pb-footer-home">回到首页，重新选择</a>
      </div>
    </div>

  </main>

  <!-- 侧边栏 -->
  <aside class="pb-aside">

    <!-- 浏览路径提示 -->
    <div class="pb-aside-card pb-progress" id="pb-progress">
      <p class="pb-aside-label">现在的位置</p>
      <ul class="pb-progress-list">
        <li class="pb-progress-item pb-progress-item--done" id="prog-problem">问题</li>
        <li class="pb-progress-item" id="prog-methods">方法</li>
        <li class="pb-progress-item" id="prog-pages">知识</li>
        <li class="pb-progress-item" id="prog-resources">资源</li>
      </ul>
    </div>

    <div class="pb-aside-card">
      <p class="pb-aside-label">问题分类</p>
      <p class="pb-aside-value">{CATEGORY_LABEL[p.category] ?? p.category}</p>
    </div>
    {p.aliases?.length > 0 && (
      <div class="pb-aside-card">
        <p class="pb-aside-label">家长也会这样描述</p>
        <ul class="pb-aside-aliases">
          {p.aliases.map((a: string) => (
            <li>{a}</li>
          ))}
        </ul>
      </div>
    )}
    <div class="pb-aside-card pb-aside-card--nav">
      <p class="pb-aside-label">继续浏览</p>
      <a href="/" class="pb-aside-link">← 返回首页</a>
      <a href="/search" class="pb-aside-link">搜索其他情况</a>
    </div>
  </aside>
</div>

<SiteFooter />
</BaseLayout>

<style>
/* ── 顶部 ─────────────────────────────────────────────── */
.pb-top {
  background: #FDFCF9;
  border-bottom: 1px solid var(--border);
  padding: var(--sp-12) 0 var(--sp-10);
}
.pb-eyebrow {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: var(--sp-3);
}
.pb-title {
  font-size: var(--text-3xl);
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.25;
  margin-bottom: var(--sp-4);
  color: var(--ink);
}
.pb-intro {
  font-size: var(--text-base);
  color: var(--muted);
  line-height: 1.8;
  max-width: 560px;
  margin-bottom: var(--sp-5);
}
.pb-aliases {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
}
.pb-alias {
  font-size: var(--text-xs);
  color: var(--muted);
  background: rgba(148,136,120,0.08);
  border: 1px solid var(--border);
  border-radius: var(--radius-pill);
  padding: var(--sp-1) var(--sp-3);
}

/* ── 行动入口 ────────────────────────────────────────────── */
.pb-anchor-wrap {
  padding: var(--sp-8) 0;
  background: white;
  border-bottom: 1px solid var(--border);
}
.pb-anchor-lead {
  font-size: var(--text-sm);
  color: var(--muted);
  margin-bottom: var(--sp-4);
}
.pb-anchor-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-4);
}
.pb-anchor-card {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  padding: var(--sp-5) var(--sp-5);
  border-radius: var(--radius-lg);
  border: 1.5px solid var(--border);
  background: white;
  text-decoration: none;
  transition: border-color 0.15s, background 0.15s;
}
.pb-anchor-title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--ink);
  line-height: 1.5;
  margin: 0;
}
.pb-anchor-desc {
  font-size: var(--text-xs);
  color: var(--muted);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}
.pb-anchor-cta {
  display: block;
  font-size: var(--text-xs);
  font-weight: 500;
  padding-top: var(--sp-3);
  border-top: 1px solid var(--border);
  margin-top: var(--sp-2);
  transition: color 0.15s;
}
.pb-anchor-card--method:hover { border-color: #2D6A8F; background: #F3F7FB; }
.pb-anchor-card--method:hover .pb-anchor-cta { color: #2D6A8F; }
.pb-anchor-card--page:hover   { border-color: #5B9E7A; background: #F4FAF7; }
.pb-anchor-card--page:hover .pb-anchor-cta   { color: #5B9E7A; }
.pb-anchor-card--resource:hover { border-color: var(--muted-lt); background: #FDFCF8; }
.pb-anchor-card--resource:hover .pb-anchor-cta { color: var(--muted); }
@media (max-width: 640px) {
  .pb-anchor-grid { grid-template-columns: 1fr; }
}

/* ── 布局 ─────────────────────────────────────────────── */
.pb-layout {
  display: grid;
  grid-template-columns: 1fr 220px;
  gap: var(--sp-16);
  align-items: start;
  padding-top: var(--sp-12);
  padding-bottom: var(--sp-24);
}
.pb-main {
  display: flex;
  flex-direction: column;
  gap: var(--sp-14);
}

/* ── 区块 ─────────────────────────────────────────────── */
.pb-section { display: flex; flex-direction: column; gap: var(--sp-5); scroll-margin-top: 80px; }
.pb-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted-lt);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--border);
}

/* ── 方法卡 ───────────────────────────────────────────── */
.pb-methods { display: flex; flex-direction: column; gap: var(--sp-4); }
.pb-method-card {
  padding: var(--sp-5) var(--sp-6);
  background: #F3F7FB;
  border-left: 3px solid #2D6A8F;
  border-radius: 0 8px 8px 0;
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}
.pb-method-name {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--ink);
}
.pb-method-core {
  font-size: var(--text-sm);
  color: var(--ink);
  line-height: 1.7;
}
.pb-method-when {
  font-size: var(--text-xs);
  color: var(--muted);
  font-style: italic;
  line-height: 1.65;
}
.pb-method-first-step {
  font-size: var(--text-sm);
  color: #1E5070;
  line-height: 1.7;
  margin-top: var(--sp-3);
  padding-top: var(--sp-3);
  border-top: 1px solid rgba(45,106,143,0.15);
}
.pb-method-first-step-label {
  font-weight: 600;
  margin-right: 0.25em;
}

/* ── 知识页卡 ─────────────────────────────────────────── */
.pb-pages { display: flex; flex-direction: column; gap: var(--sp-3); }
.pb-page-card {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  padding: var(--sp-5) var(--sp-6);
  background: #F4FAF7;
  border-left: 3px solid #5B9E7A;
  border-radius: 0 8px 8px 0;
  text-decoration: none;
  transition: background 0.15s;
}
.pb-page-card:hover { background: #ECF6F1; }
.pb-page-title {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--ink);
}
.pb-page-trigger {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.65;
}
.pb-page-why {
  font-size: var(--text-xs);
  color: var(--muted);
  line-height: 1.7;
  margin-top: var(--sp-3);
  padding-top: var(--sp-3);
  border-top: 1px solid rgba(91,158,122,0.15);
}
.pb-page-why-label {
  font-weight: 600;
  color: var(--ink);
  margin-right: 0.25em;
}
.pb-page-cta {
  font-size: var(--text-xs);
  color: #5B9E7A;
  font-weight: 500;
  margin-top: var(--sp-1);
}

/* ── 资源卡 ───────────────────────────────────────────── */
.pb-resources { display: flex; flex-direction: column; gap: var(--sp-3); }
.pb-resource-card {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  padding: var(--sp-5) var(--sp-6);
  background: #FDFCF8;
  border: 1px solid rgba(160,148,132,0.14);
  border-radius: var(--radius-md);
  text-decoration: none;
  transition: border-color 0.15s;
}
.pb-resource-card:hover { border-color: var(--muted-lt); }
.pb-resource-org {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted-lt);
}
.pb-resource-title {
  font-size: var(--text-base);
  font-weight: 500;
  color: var(--ink);
  line-height: 1.4;
}
.pb-resource-entry {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.65;
}
.pb-resource-why {
  font-size: var(--text-xs);
  color: var(--muted);
  line-height: 1.7;
  margin-top: var(--sp-3);
  padding-top: var(--sp-3);
  border-top: 1px solid rgba(160,148,132,0.14);
}
.pb-resource-why-label {
  font-weight: 600;
  color: var(--ink);
  margin-right: 0.25em;
}
.pb-resource-cta {
  font-size: var(--text-xs);
  color: var(--muted);
  font-weight: 500;
  margin-top: var(--sp-1);
}

/* ── 底部引导 ─────────────────────────────────────────── */
.pb-footer {
  padding: var(--sp-8) var(--sp-6);
  background: var(--surface-card, #F5F3EF);
  border-radius: var(--radius);
}
.pb-footer-text {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.75;
  margin-bottom: var(--sp-4);
}
.pb-footer-links {
  display: flex;
  gap: var(--sp-6);
  align-items: center;
}
.pb-footer-search {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--ink);
  border-bottom: 1px solid var(--border);
}
.pb-footer-search:hover { border-color: var(--ink); }
.pb-footer-home {
  font-size: var(--text-sm);
  color: var(--muted);
}

/* ── 侧边栏 ───────────────────────────────────────────── */
.pb-aside {
  position: sticky;
  top: 80px;
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}
.pb-aside-card {
  background: #FDFCF8;
  border: 1px solid rgba(160,148,132,0.14);
  border-radius: var(--radius-lg);
  padding: var(--sp-4) var(--sp-5);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}
.pb-aside-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted-lt);
}
.pb-aside-value { font-size: var(--text-sm); color: var(--ink); }
.pb-aside-aliases {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
}
.pb-aside-aliases li {
  font-size: var(--text-sm);
  color: var(--muted);
  line-height: 1.6;
}
.pb-aside-aliases li::before { content: "○  "; color: var(--muted-lt); }
.pb-aside-card--nav { gap: var(--sp-3); }
.pb-aside-link {
  font-size: var(--text-sm);
  color: var(--muted);
  text-decoration: none;
  border-bottom: 1px solid var(--border);
  padding-bottom: var(--sp-1);
  transition: color 0.15s;
}
.pb-aside-link:hover { color: var(--ink); }

/* ── 浏览路径提示 ─────────────────────────────────────── */
.pb-progress-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}
.pb-progress-item {
  font-size: var(--text-sm);
  color: var(--muted-lt);
  padding-left: 1.25em;
  position: relative;
  transition: color 0.2s;
}
.pb-progress-item::before {
  content: "○";
  position: absolute;
  left: 0;
  font-size: 10px;
  line-height: 1.6;
  color: var(--muted-lt);
}
.pb-progress-item--done {
  color: var(--ink);
}
.pb-progress-item--done::before {
  content: "✓";
  color: #2D6A8F;
}
@media (max-width: 860px) {
  .pb-progress { display: none; }
}

/* ── 响应式 ───────────────────────────────────────────── */
@media (max-width: 860px) {
  .pb-layout { grid-template-columns: 1fr; }
  .pb-aside { position: static; flex-direction: row; flex-wrap: wrap; }
  .pb-aside-card { flex: 1; min-width: 140px; }
}
@media (max-width: 480px) {
  .pb-title { font-size: var(--text-2xl); }
  .pb-footer-links { flex-direction: column; align-items: flex-start; gap: var(--sp-3); }
  .pb-anchor-wrap { padding: var(--sp-6) 0; }
}
</style>
<script>
  const sections = [
    { id: "methods",   prog: "prog-methods"   },
    { id: "pages",     prog: "prog-pages"     },
    { id: "resources", prog: "prog-resources" },
  ];

  const mark = (progId: string, done: boolean) => {
    const el = document.getElementById(progId);
    if (!el) return;
    el.classList.toggle("pb-progress-item--done", done);
  };

  const visited: Record<string, boolean> = {};

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const sec = sections.find((s) => s.id === entry.target.id);
        if (!sec) return;
        if (entry.isIntersecting) visited[sec.id] = true;
        mark(sec.prog, visited[sec.id] ?? false);
      });
    },
    { rootMargin: "0px 0px -30% 0px", threshold: 0 }
  );

  sections.forEach(({ id }) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
</BaseLayout>
