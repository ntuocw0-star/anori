---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import topicsData from '../../repository/library/topics.json';
import seriesData from '../../repository/library/series.json';
import { TERMS } from '../../i18n/terminology';
export function getStaticPaths(){return ((topicsData as any).topics as any[]).filter(t=>t.status==='active').map(topic=>({params:{topicSlug:topic.slug},props:{topic}}));}
const {topic}=Astro.props as any;const allSeries=(seriesData as any).series as any[];const seriesList=(topic.series??[]).map((id:string)=>allSeries.find(s=>s.id===id)).filter(Boolean).filter((s:any)=>s.status==='active').sort((a:any,b:any)=>a.order-b.order);
---
<BaseLayout title={`${topic.label} · ${TERMS.library.label} · Anori`} description={topic.description}><SiteNav /><main class="topic-page"><Breadcrumb items={[{label:'首页',href:'/'},{label:TERMS.library.label,href:'/library'},{label:topic.label}]} /><header><p class="eyebrow">{TERMS.library.label} · {TERMS.topic.label}</p><h1>{topic.label}</h1><p>{topic.description}</p></header><section><h2>{TERMS.series.label}列表</h2>{seriesList.length===0?<p class="empty">此{TERMS.topic.label}暂无已发布的{TERMS.series.label}。</p>:<div class="list">{seriesList.map((series:any)=><a class="card" href={series.canonical}><div><h3>{series.label}</h3><p>{series.description}</p></div><div class="stats"><span>{series.statistics.ea} {TERMS.ea.label}</span><span>{series.statistics.et} {TERMS.et.label}</span><span>{series.statistics.ka} {TERMS.ka.label}</span></div><strong>查看完整{TERMS.series.label} →</strong></a>)}</div>}</section></main><SiteFooter /></BaseLayout>
<style>.topic-page{max-width:760px;margin:0 auto;padding:var(--sp-6) var(--sp-6) var(--sp-24)}header{padding:var(--sp-10) 0 var(--sp-8);border-bottom:1px solid var(--border);margin-bottom:var(--sp-8)}.eyebrow{font-size:var(--text-xs);letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}header h1{font-size:var(--text-3xl);margin:var(--sp-2) 0}header>p:last-child{color:var(--muted)}section>h2{font-size:var(--text-sm);text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:var(--sp-4)}.list{display:flex;flex-direction:column;gap:var(--sp-4)}.card{padding:var(--sp-6);border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--surface)}.card h3{font-size:var(--text-lg)}.card p{font-size:var(--text-sm);color:var(--muted);margin-top:var(--sp-2)}.stats{display:flex;gap:var(--sp-5);color:var(--muted);font-size:var(--text-xs);margin:var(--sp-4) 0}.card>strong{color:var(--brand);font-size:var(--text-sm)}.empty{color:var(--muted)}</style>
