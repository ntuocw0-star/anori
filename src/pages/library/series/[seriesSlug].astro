---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteNav from '../../../components/SiteNav.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import seriesData from '../../../repository/library/series.json';
import topicsData from '../../../repository/library/topics.json';
import eaData from '../../../generated/evidence/ea.json';
import etData from '../../../generated/evidence/et.json';
import kaData from '../../../repository/knowledge.json';
import { normalizeAllEA } from '../../../repository/adapters/ea';
import { normalizeAllET } from '../../../repository/adapters/et';
import { normalizeAllKA } from '../../../repository/adapters/ka';
import { TERMS } from '../../../i18n/terminology';

export function getStaticPaths() {
  return ((seriesData as any).series as any[])
    .filter(series => series.status === 'active')
    .map(series => ({ params: { seriesSlug: series.slug }, props: { series } }));
}

const { series } = Astro.props as any;
const topic = ((topicsData as any).topics as any[]).find(item => item.id === series.topic);
const eaMap = new Map(normalizeAllEA(eaData as any).map(item => [item.id, item]));
const etMap = new Map(normalizeAllET(etData as any).map(item => [item.id, item]));
const kaMap = new Map(normalizeAllKA(kaData as any).map(item => [item.id, item]));
const refs = series.content_refs ?? {};
const eaItems = (refs.ea ?? []).map((id: string) => eaMap.get(id) ?? { id, missing: true });
const etItems = (refs.et ?? []).map((id: string) => etMap.get(id) ?? { id, missing: true });
const kaItems = (refs.ka ?? []).map((id: string) => kaMap.get(id) ?? { id, missing: true });
const eaTitle = (item: any) => item.displayTitle ?? item.source?.paperTitle ?? item.id;
const eaPaperTitle = (item: any) => item.displayTitle ? (item.source?.paperTitle ?? null) : null;
const etTitle = (item: any) => item.topic ?? item.id;
const kaTitle = (item: any) => item.title ?? item.id;
const etPreview = (item: any) => {
  if (!item.body) return undefined;
  const plain = item.body.replace(/[#*`>\-_]/g, "").replace(/\s+/g, " ").trim();
  return plain.length > 80 ? plain.slice(0, 80) + "……" : plain;
};
---
<BaseLayout title={`${series.label} · ${TERMS.library.label} · Anori`} description={series.description}>
  <SiteNav />
  <main class="series-page">
    <Breadcrumb items={[
      { label: '首页', href: '/' },
      { label: TERMS.library.label, href: '/library' },
      ...(topic ? [{ label: topic.label, href: `/library/${topic.slug}` }] : []),
      { label: series.label },
    ]} />

    <header>
      {topic && <a class="topic-badge" href={`/library/${topic.slug}`}>{topic.label}</a>}
      <h1>{series.label}</h1>
      <p>{series.description}</p>
      <div class="stats">
        {kaItems.length > 0 && <span><strong>{kaItems.length}</strong>先看这里</span>}
        {etItems.length > 0 && <span><strong>{etItems.length}</strong>为什么</span>}
        {eaItems.length > 0 && <span><strong>{eaItems.length}</strong>研究证据</span>}
      </div>
    </header>

    {/* KA 第一：问题入口 */}
    {kaItems.length > 0 && (
      <section class="content-section ka-first">
        <h2><span>{TERMS.ka.abbr}</span>{TERMS.ka.label}</h2>
        <p class="intro">先从这里开始——3 分钟了解核心知识，今天就能用。</p>
        <ul>
          {kaItems.map((item: any) => {
            const missing = 'missing' in item;
            return <li class:list={[missing && 'missing', 'ka-item']}>
              {missing ? (
                <div class="static"><div><strong>内容记录暂未找到</strong></div><small>引用断链</small></div>
              ) : (
                <a href={`/library/ka/${item.id}`}>
                  <div>
                    <strong>{kaTitle(item)}</strong>
                    {item.summary && <em class="one-liner">{item.summary}</em>}
                  </div>
                  <span>→</span>
                </a>
              )}
            </li>;
          })}
        </ul>
      </section>
    )}

    {/* ET 第二：为什么 */}
    {etItems.length > 0 && (
      <section class="content-section">
        <h2><span>{TERMS.et.abbr}</span>{TERMS.et.label}</h2>
        <p class="intro">想了解为什么——将研究发现转化为更容易理解的说明。</p>
        <ul>
          {etItems.map((item: any) => {
            const missing = 'missing' in item;
            return <li class:list={[missing && 'missing']}>
              {missing ? (
                <div class="static"><div><strong>内容记录暂未找到</strong></div><small>引用断链</small></div>
              ) : (
                <a href={`/library/et/${item.id}`}>
                  <div>
                    <strong>{etTitle(item)}</strong>
                    {etPreview(item) && <em class="et-preview">{etPreview(item)}</em>}
                  </div>
                  <span>→</span>
                </a>
              )}
            </li>;
          })}
        </ul>
      </section>
    )}

    {/* EA 最后：证据来源 */}
    {eaItems.length > 0 && (
      <section class="content-section ea-last">
        <h2><span>{TERMS.ea.abbr}</span>{TERMS.ea.label}</h2>
        <p class="intro">想看研究证据——每篇对应一项同行评审研究。</p>
        <ul>
          {eaItems.map((item: any) => {
            const missing = 'missing' in item;
            return <li class:list={[missing && 'missing']}>
              {missing ? (
                <div class="static"><div><strong>内容记录暂未找到</strong></div><small>引用断链</small></div>
              ) : (
                <a href={`/library/ea/${item.id}`}>
                  <div>
                    <strong>{eaTitle(item)}</strong>
                    {eaPaperTitle(item) && <em class="ea-sub">{eaPaperTitle(item)}</em>}
                  </div>
                  <span>→</span>
                </a>
              )}
            </li>;
          })}
        </ul>
      </section>
    )}

    <section class="bridge">
      <p>想找更多相关内容？</p>
      <a href={`/search?q=${encodeURIComponent(series.label)}`}>在{TERMS.search.label}中查看相关结果 →</a>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
.series-page { max-width: 760px; margin: 0 auto; padding: var(--sp-6) var(--sp-6) var(--sp-24); }
header { padding: var(--sp-10) 0 var(--sp-8); border-bottom: 1px solid var(--border); margin-bottom: var(--sp-8); }
.topic-badge { font-size: var(--text-xs); color: var(--brand); border: 1px solid rgba(45,106,143,.3); padding: .2rem .55rem; border-radius: var(--radius-pill); text-decoration: none; }
header h1 { font-size: var(--text-3xl); margin: var(--sp-3) 0; }
header > p { color: var(--muted); }
.stats { display: flex; gap: var(--sp-8); margin-top: var(--sp-5); padding-top: var(--sp-4); border-top: 1px solid var(--border); font-size: var(--text-xs); color: var(--muted); }
.stats strong { display: block; font-size: var(--text-xl); color: var(--ink); }

.content-section { margin-top: var(--sp-10); }
.content-section h2 { display: flex; align-items: center; gap: var(--sp-2); font-size: var(--text-lg); }
.content-section h2 span { font-size: var(--text-xs); background: var(--surface-card); padding: .15rem .45rem; border-radius: var(--radius-sm); }
.intro { font-size: var(--text-sm); color: var(--muted); margin: var(--sp-2) 0 var(--sp-4); }

.ka-first { padding: var(--sp-6); background: rgba(37,99,235,.04); border: 1px solid rgba(37,99,235,.12); border-radius: var(--radius-lg); margin-top: var(--sp-8); }
.ka-first h2 { margin-bottom: 0; }
.ka-first h2 span { background: rgba(37,99,235,.1); color: var(--brand); }
.ka-item > a { align-items: flex-start; }
.one-liner { display: block; font-style: normal; font-size: var(--text-sm); color: var(--muted); margin-top: var(--sp-1); }
.et-preview { display: block; font-style: normal; font-size: var(--text-sm); color: var(--muted); margin-top: var(--sp-1); line-height: 1.5; }

.ea-last { opacity: .85; }
.ea-sub { display: block; font-style: italic; font-size: var(--text-xs); color: var(--muted); margin-top: var(--sp-1); line-height: 1.4; }

ul { list-style: none; display: flex; flex-direction: column; gap: var(--sp-2); }
li { border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); }
li > a, .static { display: flex; justify-content: space-between; align-items: center; gap: var(--sp-4); padding: var(--sp-4); text-decoration: none; color: inherit; }
li strong { display: block; font-size: var(--text-sm); line-height: 1.5; }
.static small { color: var(--muted); }
li.missing { border-style: dashed; opacity: .6; }

.bridge { margin-top: var(--sp-10); border-top: 1px solid var(--border); padding-top: var(--sp-5); font-size: var(--text-sm); }
.bridge p { color: var(--muted); }
.bridge a { color: var(--brand); }

@media(max-width: 560px) { .stats { gap: var(--sp-4); flex-wrap: wrap; } }
</style>
