  },
  "definition": {
    "anori": "社区参与不只是「出去活动」，而是感到自己还属于比家庭更大的世界——有人认识你，你参与了一件事，你在那里是有意义的。它可以很小：一个固定见面的朋友、一项喜欢的活动、一个社区里有你位置的地方。不需要很多，但需要真实。",
    "research": "个体参与社区活动、社会角色和公共生活的程度，包括频率、投入度和多样性。基于 ICF 定义，社区参与是人与环境互动的结果，受到个人因素和环境因素共同影响。",
    "model": "Community Participation Model（建立分析框架）：Access（可及性）/ Relationships（关系）/ Decision（决策参与）/ Roles（社会角色）/ Belonging（归属感）",
    "icf_alignment": "Activities & Participation (d9)：社区、社会和公民生活"
  },
  "why_it_matters": "Community Participation 是整个 Participation Science 证据最稳固的节点。经典综述和大规模研究一致发现，社区参与程度和生活质量、家庭生活质量、照顾者负担都有可测量的关联。它同时是 Belonging 的前驱变量，也是 Family QoL 的重要预测因子（双向关系）。",
  "dimensions": [
    {
      "dimension": "可及性（Access）",
      "description": "物理环境、交通、费用等进入社区的条件"
    },
    {
      "dimension": "关系（Relationships）",
      "description": "社区中的人际联结和友谊"
    },
    {
      "dimension": "决策参与（Decision）",
      "description": "在社区事务中的发言权和自主权"
    },
    {
      "dimension": "社会角色（Roles）",
      "description": "在社区中承担的有意义角色"
    },
    {
      "dimension": "归属感（Belonging）",
      "description": "感到自己属于这个社区的主观体验"
    }
  ],
